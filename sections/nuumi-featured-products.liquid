{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-featured-products section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-featured-products__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-featured-products__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nuumi-featured-products__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-featured-products__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-featured-products__grid">
      {%- for block in section.blocks limit: 4 -%}
        {%- assign product_card = block.settings.product -%}
        {%- if product_card == blank -%}
          {%- continue -%}
        {%- endif -%}
        {%- assign card_url = product_card.url -%}
        {%- if block.settings.link != blank -%}
          {%- assign card_url = block.settings.link -%}
        {%- endif -%}
        {%- assign card_benefit = product_card.metafields.custom.benefit.value -%}
        {%- assign rating_value = block.settings.rating -%}
        {%- assign rating_count_value = block.settings.rating_count -%}

        <article class="nuumi-featured-products__card" {{ block.shopify_attributes }}>
          <div class="nuumi-featured-products__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag:
                class: 'nuumi-featured-products__image',
                loading: 'lazy',
                widths: '320, 480, 720, 900',
                alt: product_card.title | escape
              }}
            {%- elsif product_card != blank and product_card.featured_image != blank -%}
              {{ product_card.featured_image | image_url: width: 800 | image_tag:
                class: 'nuumi-featured-products__image',
                loading: 'lazy',
                widths: '320, 480, 720, 800',
                alt: product_card.featured_image.alt | escape
              }}
            {%- else -%}
              <div class="nuumi-featured-products__image-placeholder">
                {% render 'nuumi-icons', icon: 'paw', class: 'nuumi-featured-products__placeholder-icon' %}
              </div>
            {%- endif -%}

            {%- if card_benefit != blank -%}
              <span class="nuumi-featured-products__badge">{{ card_benefit | escape }}</span>
            {%- endif -%}
          </div>

          <div class="nuumi-featured-products__body">
            <div class="nuumi-featured-products__meta">
              <div>
                <h3 class="nuumi-featured-products__title">{{ product_card.title | escape }}</h3>
                {%- if card_benefit != blank -%}
                  <p class="nuumi-featured-products__benefit">{{ card_benefit | escape }}</p>
                {%- endif -%}
              </div>
              <p class="nuumi-featured-products__price">{{ product_card.price | money }}</p>
            </div>

            <div class="nuumi-featured-products__rating">
              {% render 'nuumi-rating-stars', rating: rating_value, count: rating_count_value %}
            </div>

            <p class="nuumi-featured-products__summary">{{ product_card.description | strip_html | truncatewords: 18 }}</p>

            {%- if card_url != blank -%}
              <a class="nuumi-button--gold nuumi-featured-products__cta" href="{{ card_url }}">
                {{ block.settings.button_label | default: 'Shop now' | escape }}
              </a>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Daily wellness lineup"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Five focused formulas. One calmer, healthier routine."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Keep every launch product visible from the homepage with editorial product cards that make benefits and trust cues easy to scan.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "Best seller"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override title"
        },
        {
          "type": "text",
          "id": "benefit",
          "label": "Primary benefit",
          "default": "Daily calm, comfort, and confidence support."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Override price"
        },
        {
          "type": "textarea",
          "id": "summary",
          "label": "Summary",
          "default": "Built for pet parents who want visible support without guesswork or filler-heavy formulas."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "default": 4.8
        },
        {
          "type": "number",
          "id": "rating_count",
          "label": "Rating count",
          "default": 128
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Override link"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Nuumi Featured Products",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
