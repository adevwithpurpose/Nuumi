{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-featured-products section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-featured-products__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-featured-products__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nuumi-featured-products__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-featured-products__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-featured-products__grid">
      {%- for block in section.blocks -%}
        {%- assign product_card = block.settings.product -%}
        {%- if product_card == blank -%}
          {%- continue -%}
        {%- endif -%}
        {%- assign card_url = product_card.url -%}
        {%- assign card_badge = block.settings.badge | default: product_card.metafields.custom.benefit.value -%}
        {%- assign card_title = product_card.title -%}
        {%- assign card_price = product_card.price | money -%}
        {%- assign card_summary = product_card.description | strip_html | truncatewords: 14 -%}
        {%- assign rating_value = block.settings.rating -%}
        {%- assign rating_count_value = block.settings.rating_count -%}
        {%- if rating_value == blank or rating_value <= 0 -%}
          {%- assign rating_value = product_card.metafields.reviews.rating.value -%}
        {%- endif -%}
        {%- if rating_count_value == blank or rating_count_value <= 0 -%}
          {%- assign rating_count_value = product_card.metafields.reviews.rating_count.value | default: product_card.metafields.reviews.rating_count -%}
        {%- endif -%}

        <article class="nuumi-featured-products__card" {{ block.shopify_attributes }}>
          <div class="nuumi-featured-products__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 1400 | image_tag:
                class: 'nuumi-featured-products__image',
                loading: 'lazy',
                sizes: '(min-width: 990px) 30vw, (min-width: 750px) 50vw, 100vw',
                widths: '320, 480, 720, 900, 1100, 1400',
                alt: product_card.title | escape
              }}
            {%- elsif product_card != blank and product_card.featured_image != blank -%}
              {{ product_card.featured_image | image_url: width: 1400 | image_tag:
                class: 'nuumi-featured-products__image',
                loading: 'lazy',
                sizes: '(min-width: 990px) 30vw, (min-width: 750px) 50vw, 100vw',
                widths: '320, 480, 720, 900, 1100, 1400',
                alt: product_card.featured_image.alt | escape
              }}
            {%- else -%}
              <div class="nuumi-featured-products__image-placeholder">
                {% render 'nuumi-icons', icon: 'paw', class: 'nuumi-featured-products__placeholder-icon' %}
              </div>
            {%- endif -%}

          </div>

          <div class="nuumi-featured-products__body">
            <div class="nuumi-featured-products__pitch">
              {%- if card_badge != blank -%}
                <p class="nuumi-featured-products__card-eyebrow">{{ card_badge | escape }}</p>
              {%- endif -%}

              {%- if rating_value != blank and rating_value > 0 -%}
                <div class="nuumi-featured-products__rating">
                  {% render 'nuumi-rating-stars', rating: rating_value, count: rating_count_value %}
                </div>
              {%- endif -%}

              <div class="nuumi-featured-products__meta">
                <div>
                  <h3 class="nuumi-featured-products__title">{{ card_title | escape }}</h3>
                </div>
              </div>

              <p class="nuumi-featured-products__summary">{{ card_summary | escape }}</p>
            </div>

            <div class="nuumi-featured-products__action">
              <p class="nuumi-featured-products__price">{{ card_price }}</p>

              {%- if card_url != blank -%}
                <a class="nuumi-button--gold nuumi-featured-products__cta" href="{{ card_url }}">
                  {{ block.settings.button_label | default: 'Shop now' | escape }}
                </a>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Featured Products",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Start with two essentials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A focused routine beats a crowded shelf."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Lead with two or three problem-solving essentials so the homepage feels guided, calm, and easy to shop at a glance.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Override image"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge",
          "default": "Targeted support"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Override title"
        },
        {
          "type": "text",
          "id": "benefit",
          "label": "Primary benefit",
          "default": "A clear daily support story for a specific pet need."
        },
        {
          "type": "text",
          "id": "price",
          "label": "Override price"
        },
        {
          "type": "textarea",
          "id": "summary",
          "label": "Summary",
          "default": "Lead with the problem it helps solve, what kind of support it offers, and why it feels easier to trust than a generic wellness product."
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "default": 4.8
        },
        {
          "type": "number",
          "id": "rating_count",
          "label": "Rating count",
          "default": 128
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "View product"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Override link"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Nuumi Featured Products",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
