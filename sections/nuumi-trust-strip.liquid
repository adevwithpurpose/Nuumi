{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-trust-strip">
  <div class="nuumi-trust-strip__marquee">
    <div class="nuumi-trust-strip__content">
      {%- for block in section.blocks -%}
        <div class="nuumi-trust-strip__item" {{ block.shopify_attributes }}>
          {% render 'nuumi-icon-media', icon_source: block.settings.icon_source, icon: block.settings.icon, custom_svg: block.settings.custom_svg, image: block.settings.custom_image, wrapper_class: 'nuumi-trust-strip__icon', icon_class: 'nuumi-trust-strip__icon', image_width: 64, image_sizes: '32px', image_widths: '32, 48, 64', alt: block.settings.text %}
          <span class="nuumi-trust-strip__text">{{ block.settings.text | escape }}</span>
        </div>
      {%- endfor -%}
      {%- for block in section.blocks -%}
        <div class="nuumi-trust-strip__item">
          {% render 'nuumi-icon-media', icon_source: block.settings.icon_source, icon: block.settings.icon, custom_svg: block.settings.custom_svg, image: block.settings.custom_image, wrapper_class: 'nuumi-trust-strip__icon', icon_class: 'nuumi-trust-strip__icon', image_width: 64, image_sizes: '32px', image_widths: '32, 48, 64', alt: block.settings.text %}
          <span class="nuumi-trust-strip__text">{{ block.settings.text | escape }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Trust Strip",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Animation Speed",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon_source",
          "label": "Icon Source",
          "options": [
            { "value": "icon", "label": "Theme Icon" },
            { "value": "svg", "label": "Custom SVG" },
            { "value": "image", "label": "Image" }
          ],
          "default": "icon"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "paw", "label": "Paw" },
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "check_mark", "label": "Check Mark" },
            { "value": "star", "label": "Star" },
            { "value": "truck", "label": "Truck" },
            { "value": "return", "label": "Return" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "check_mark"
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG Markup"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trusted by 10,000+ Pet Parents"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Trust Strip",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "science",
            "text": "VET FORMULATED"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "text": "MADE IN THE USA"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "leaf",
            "text": "100% NATURAL"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "star",
            "text": "5-STAR RATED"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .nuumi-trust-strip__content {
    animation-duration: {{ section.settings.speed }}s;
  }
</style>
