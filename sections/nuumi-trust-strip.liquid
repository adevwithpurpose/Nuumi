{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-trust-strip">
  <div class="nuumi-trust-strip__marquee">
    <div class="nuumi-trust-strip__content">
      {%- for block in section.blocks -%}
        <div class="nuumi-trust-strip__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != 'none' -%}
            {% render 'nuumi-icons', icon: block.settings.icon, class: 'nuumi-trust-strip__icon' %}
          {%- endif -%}
          <span class="nuumi-trust-strip__text">{{ block.settings.text | escape }}</span>
        </div>
      {%- endfor -%}
      {%- for block in section.blocks -%}
        <div class="nuumi-trust-strip__item">
          {%- if block.settings.icon != 'none' -%}
            {% render 'nuumi-icons', icon: block.settings.icon, class: 'nuumi-trust-strip__icon' %}
          {%- endif -%}
          <span class="nuumi-trust-strip__text">{{ block.settings.text | escape }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Trust Strip",
  "settings": [
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 60,
      "step": 1,
      "unit": "s",
      "label": "Animation Speed",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "paw", "label": "Paw" },
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "check_mark", "label": "Check Mark" },
            { "value": "star", "label": "Star" },
            { "value": "truck", "label": "Truck" },
            { "value": "return", "label": "Return" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "check_mark"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trusted by 10,000+ Pet Parents"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Trust Strip",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "science",
            "text": "VET FORMULATED"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "shield",
            "text": "MADE IN THE USA"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "leaf",
            "text": "100% NATURAL"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "star",
            "text": "5-STAR RATED"
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .nuumi-trust-strip__content {
    animation-duration: {{ section.settings.speed }}s;
  }
</style>
