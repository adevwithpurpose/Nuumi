<product-info
  id="MainProduct-{{ section.id }}"
  class="nuumi-pdp nuumi-pdp--calmicollar section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
  {% assign current_variant = product.selected_or_first_available_variant %}
  {% assign base_price = current_variant.price | default: product.price %}
  {% assign base_compare_at_price = current_variant.compare_at_price | default: product.compare_at_price %}
  {% assign has_compare_at_price = false %}
  {% if base_compare_at_price and base_compare_at_price > base_price %}
    {% assign has_compare_at_price = true %}
  {% endif %}
  {% assign pack_blocks = section.blocks | where: 'type', 'pack_option' %}
  {% assign first_pack = pack_blocks | first %}
  {% assign default_quantity = first_pack.settings.quantity | default: 1 %}
  {% assign one_time_total_price = base_price | times: default_quantity %}
  {% assign one_time_compare_total_price = base_compare_at_price | times: default_quantity %}
  {% assign form_id = 'product-form-' | append: section.id %}
  {% assign default_bundle_title = first_pack.settings.title | default: '1 Bottle' %}
  {% assign subscribe_enabled = false %}

  <div class="page-width">
    <div class="nuumi-calmicollar-hero">
      {% render 'nuumi-hero-gallery',
        variant_images: variant_images,
        section: section,
        shell_class: 'nuumi-calmicollar-hero__media-shell',
        media_column_class: 'nuumi-calmicollar-hero__media-column',
        show_left_guarantee: true,
        left_guarantee_class_prefix: 'nuumi-calmicollar-hero',
        fallback_guarantee_text: '30-Day',
        hide_variants: true
      %}

      <div class="nuumi-calmicollar-hero__content-column">
        <section id="ProductInfo-{{ section.id }}" class="nuumi-calmicollar-hero__panel">
          <div class="nuumi-calmicollar-hero__intro">
            {%- if section.settings.eyebrow != blank -%}
              <p class="nuumi-calmicollar-hero__eyebrow">{{ section.settings.eyebrow }}</p>
            {%- endif -%}

            <div class="nuumi-calmicollar-hero__badge-row">
              {%- if section.settings.badge_primary != blank -%}
                <span class="nuumi-calmicollar-hero__badge">{{ section.settings.badge_primary }}</span>
              {%- endif -%}
              {%- if section.settings.badge_secondary != blank -%}
                <span class="nuumi-calmicollar-hero__badge nuumi-calmicollar-hero__badge--soft">{{ section.settings.badge_secondary }}</span>
              {%- endif -%}
            </div>

            <p class="nuumi-calmicollar-hero__product-name">{{ product.title | escape }}</p>
            <h1 class="nuumi-calmicollar-hero__title">{{ section.settings.headline | default: product.title | escape }}</h1>

            {%- if section.settings.subtitle != blank -%}
              <p class="nuumi-calmicollar-hero__subtitle">{{ section.settings.subtitle }}</p>
            {%- endif -%}

            <div class="nuumi-calmicollar-hero__rating-row">
              {% render 'nuumi-rating-stars', rating: section.settings.rating_value, count: section.settings.review_count, class: 'nuumi-calmicollar-hero__rating' %}
              {%- if section.settings.rating_caption != blank -%}
                <span class="nuumi-calmicollar-hero__rating-caption">{{ section.settings.rating_caption }}</span>
              {%- endif -%}
            </div>

            {%- if section.settings.description != blank -%}
              <div class="nuumi-calmicollar-hero__description rte">{{ section.settings.description }}</div>
            {%- endif -%}
          </div>

          {%- assign support_blocks = section.blocks | where: 'type', 'support_point' -%}
          {%- if support_blocks.size > 0 -%}
            <div class="nuumi-calmicollar-hero__support-grid">
              {%- for block in support_blocks -%}
                <article class="nuumi-calmicollar-hero__support-card" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    <span class="nuumi-calmicollar-hero__support-media nuumi-calmicollar-hero__support-media--image">
                      {{ block.settings.image | image_url: width: 96 | image_tag:
                        loading: 'lazy',
                        class: 'nuumi-calmicollar-hero__support-image',
                        widths: '48, 72, 96'
                      }}
                    </span>
                  {%- else -%}
                    <span class="nuumi-calmicollar-hero__support-media nuumi-calmicollar-hero__support-media--icon">{% render 'nuumi-icons', icon: block.settings.icon %}</span>
                  {%- endif -%}
                  <div>
                    <p class="nuumi-calmicollar-hero__support-title">{{ block.settings.title }}</p>
                    {%- if block.settings.text != blank -%}
                      <p class="nuumi-calmicollar-hero__support-text">{{ block.settings.text }}</p>
                    {%- endif -%}
                  </div>
                </article>
              {%- endfor -%}
            </div>
          {%- endif -%}

            <div class="nuumi-calmicollar-hero__purchase-card">
              <div class="nuumi-calmicollar-hero__mode-group">
                <p class="nuumi-calmicollar-hero__purchase-label">{{ section.settings.purchase_mode_heading }}</p>
                <div class="nuumi-calmicollar-hero__mode-grid">
                  <label class="nuumi-calmicollar-hero__mode {% unless subscribe_enabled %}is-selected{% endunless %}" data-mode-card="one_time">
                    <input
                      type="radio"
                      name="calmicollar_mode_{{ section.id }}"
                      value="one_time"
                      data-mode="one_time"
                      {% unless subscribe_enabled %}checked{% endunless %}
                    >
                    <span class="nuumi-calmicollar-hero__mode-copy">
                      <span class="nuumi-calmicollar-hero__mode-title">{{ section.settings.one_time_label }}</span>
                      <span class="nuumi-calmicollar-hero__mode-text">{{ section.settings.one_time_mode_text }}</span>
                    </span>
                  </label>

                  <label class="nuumi-calmicollar-hero__mode is-disabled" data-mode-card="subscribe" aria-disabled="true" title="Subscription option will be enabled after the subscription app is configured.">
                      <input
                        type="radio"
                        name="calmicollar_mode_{{ section.id }}"
                        value="subscribe"
                        data-mode="subscribe"
                        disabled
                      >
                      <span class="nuumi-calmicollar-hero__mode-copy">
                        <span class="nuumi-calmicollar-hero__mode-badge">{{ section.settings.subscribe_badge }}</span>
                        <span class="nuumi-calmicollar-hero__mode-title">{{ section.settings.subscribe_label }}</span>
                        <span class="nuumi-calmicollar-hero__mode-text">Subscription option coming soon once the app is configured.</span>
                      </span>
                      <span class="nuumi-calmicollar-hero__mode-overlay" aria-hidden="true"></span>
                    </label>
                </div>
              </div>

              <div class="nuumi-calmicollar-hero__price-row">
                <div>
                  {%- if section.settings.price_label != blank -%}
                  <p class="nuumi-calmicollar-hero__price-label">{{ section.settings.price_label }}</p>
                {%- endif -%}
                <p class="nuumi-calmicollar-hero__price" data-total-price>{{ one_time_total_price | money }}</p>
              </div>
              <div class="nuumi-calmicollar-hero__price-meta">
                {%- if has_compare_at_price -%}
                  <p class="nuumi-calmicollar-hero__compare-at" data-compare-price>{{ one_time_compare_total_price | money }}</p>
                {%- else -%}
                  <p class="nuumi-calmicollar-hero__compare-at" data-compare-price style="display:none"></p>
                {%- endif -%}
                {%- if section.settings.one_time_badge != blank -%}
                  <span class="nuumi-calmicollar-hero__price-chip" data-price-chip>{{ section.settings.one_time_badge }}</span>
                {%- endif -%}
                <p class="nuumi-calmicollar-hero__price-note" data-price-note>{{ section.settings.one_time_note }}</p>
              </div>
            </div>

            {%- if pack_blocks.size > 0 -%}
              <div class="nuumi-calmicollar-hero__packs">
                <p class="nuumi-calmicollar-hero__packs-heading">{{ section.settings.pack_heading }}</p>
                <div class="nuumi-calmicollar-hero__pack-grid">
                  {%- for block in pack_blocks -%}
                    {%- assign is_default = false -%}
                    {%- if forloop.first -%}
                      {%- assign is_default = true -%}
                    {%- endif -%}
                    <label class="nuumi-calmicollar-hero__pack {% if is_default %}is-selected{% endif %}" {{ block.shopify_attributes }}>
                      <input
                        type="radio"
                        name="calmicollar_pack_{{ section.id }}"
                        value="{{ block.settings.quantity }}"
                        data-qty="{{ block.settings.quantity }}"
                        data-title="{{ block.settings.title | escape }}"
                        data-discount="{{ block.settings.discount_percent | default: 0 }}"
                        {% if is_default %}checked{% endif %}
                      >
                      {%- if block.settings.badge != blank -%}
                        <span class="nuumi-calmicollar-hero__pack-badge">{{ block.settings.badge }}</span>
                      {%- endif -%}
                      <span class="nuumi-calmicollar-hero__pack-title">{{ block.settings.title }}</span>
                      {%- if block.settings.subtitle != blank -%}
                        <span class="nuumi-calmicollar-hero__pack-subtitle">{{ block.settings.subtitle }}</span>
                      {%- endif -%}
                      {%- if block.settings.note != blank -%}
                        <span class="nuumi-calmicollar-hero__pack-note">{{ block.settings.note }}</span>
                      {%- endif -%}
                      <span class="nuumi-calmicollar-hero__pack-per" data-pack-per></span>
                      <span class="nuumi-calmicollar-hero__pack-save" data-pack-save></span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}

            <product-form class="product-form" data-section-id="{{ section.id }}">
              <div class="product-form__error-message-wrapper" role="alert" hidden>
                <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                <span class="product-form__error-message"></span>
              </div>

              {%- form 'product', product, id: form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id">
                <input type="hidden" name="quantity" value="{{ default_quantity }}" data-quantity-input>
                <input type="hidden" name="properties[Purchase option]" value="{% if subscribe_enabled %}{{ section.settings.subscribe_label }}{% else %}{{ section.settings.one_time_label }}{% endif %}" data-purchase-option>
                <input type="hidden" name="properties[Bundle]" value="{{ default_bundle_title }}" data-bundle-label>

                <div class="nuumi-calmicollar-hero__cta-group">
                  <button
                    id="ProductSubmitButton-{{ section.id }}"
                    type="submit"
                    name="add"
                    class="nuumi-button--gold nuumi-calmicollar-hero__cta product-form__submit"
                    {% if current_variant.available == false %}disabled{% endif %}
                  >
                    <span data-atc-label>
                      {%- if current_variant.available == false -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- else -%}
                        {%- if subscribe_enabled -%}
                          {{ section.settings.subscribe_cta_label }}
                        {%- else -%}
                          {{ section.settings.cta_label }}
                        {%- endif -%}
                      {%- endif -%}
                    </span>
                    {%- render 'loading-spinner' -%}
                  </button>

                  {%- if section.settings.one_time_cta_note != blank -%}
                    <p class="nuumi-calmicollar-hero__cta-note" data-cta-note>{{ section.settings.one_time_cta_note }}</p>
                  {%- endif -%}
                </div>
              {%- endform -%}
            </product-form>

            <div class="nuumi-calmicollar-hero__micro-trust">
              {%- if section.settings.shipping_note != blank -%}
                <span>{{ section.settings.shipping_note }}</span>
              {%- endif -%}
              {%- if section.settings.guarantee_note != blank -%}
                <span>{{ section.settings.guarantee_note }}</span>
              {%- endif -%}
              {%- if section.settings.payment_note != blank -%}
                <span>{{ section.settings.payment_note }}</span>
              {%- endif -%}
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</product-info>

{%- if section.settings.enable_sticky_cta -%}
  <div class="nuumi-sticky-cta nuumi-sticky-cta--calmicollar" data-sticky-cta>
    <div class="nuumi-sticky-cta__inner page-width">
      <div class="nuumi-sticky-cta__info">
        <span class="nuumi-sticky-cta__title">{{ product.title }}</span>
        <span class="nuumi-sticky-cta__price" data-sticky-price>{{ one_time_total_price | money }}</span>
      </div>
      <button type="button" class="nuumi-button--gold nuumi-sticky-cta__button" data-sticky-button>
        {{ section.settings.sticky_button_label }}
      </button>
    </div>
  </div>
{%- endif -%}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var sectionRoot = document.getElementById('MainProduct-{{ section.id }}');
    if (!sectionRoot) return;

    var basePrice = {{ base_price | json }};
    var baseCompareAtPrice = {{ base_compare_at_price | default: 0 | json }};
    var sectionSettings = {
      subscribeEnabled: {{ section.settings.enable_subscribe_mode | json }},
      subscribeDiscountPercent: {{ section.settings.subscribe_discount_percent | default: 0 | json }},
      oneTimeLabel: {{ section.settings.one_time_label | json }},
      oneTimeModeText: {{ section.settings.one_time_mode_text | json }},
      oneTimeNote: {{ section.settings.one_time_note | json }},
      oneTimeBadge: {{ section.settings.one_time_badge | json }},
      ctaLabel: {{ section.settings.cta_label | json }},
      stickyLabel: {{ section.settings.sticky_button_label | json }},
      oneTimeCtaNote: {{ section.settings.one_time_cta_note | json }},
      subscribeLabel: {{ section.settings.subscribe_label | json }},
      subscribeBadge: {{ section.settings.subscribe_badge | json }},
      subscribeNote: {{ section.settings.subscribe_note | json }},
      subscribeCtaLabel: {{ section.settings.subscribe_cta_label | json }},
      subscribeCtaNote: {{ section.settings.subscribe_cta_note | json }}
    };

    var priceEl = sectionRoot.querySelector('[data-total-price]');
    var stickyPriceEl = document.querySelector('.nuumi-sticky-cta--calmicollar [data-sticky-price]');
    var quantityInput = sectionRoot.querySelector('[data-quantity-input]');
    var bundleInput = sectionRoot.querySelector('[data-bundle-label]');
    var atcLabel = sectionRoot.querySelector('[data-atc-label]');
    var ctaNote = sectionRoot.querySelector('[data-cta-note]');
    var priceNote = sectionRoot.querySelector('[data-price-note]');
    var comparePriceEl = sectionRoot.querySelector('[data-compare-price]');
    var priceChip = sectionRoot.querySelector('[data-price-chip]');
    var packInputs = sectionRoot.querySelectorAll('input[name="calmicollar_pack_{{ section.id }}"]');
    var modeInputs = sectionRoot.querySelectorAll('input[name="calmicollar_mode_{{ section.id }}"]');
    var purchaseOptionInput = sectionRoot.querySelector('[data-purchase-option]');
    var stickyCta = document.querySelector('.nuumi-sticky-cta--calmicollar[data-sticky-cta]');
    var stickyButton = stickyCta ? stickyCta.querySelector('[data-sticky-button]') : null;
    var submitButton = document.getElementById('ProductSubmitButton-{{ section.id }}');
    var buyCard = sectionRoot.querySelector('.nuumi-calmicollar-hero__purchase-card');

    function formatMoney(cents) {
      if (!window.Shopify || typeof window.Shopify.formatMoney !== 'function') {
        return '$' + (cents / 100).toFixed(2);
      }
      return window.Shopify.formatMoney(cents);
    }

    function getSelectedPack() {
      var checked = sectionRoot.querySelector('input[name="calmicollar_pack_{{ section.id }}"]:checked');
      return checked || packInputs[0];
    }

    function getSelectedMode() {
      var checkedMode = sectionRoot.querySelector('input[name="calmicollar_mode_{{ section.id }}"]:checked');
      return checkedMode ? checkedMode.value : 'one_time';
    }

    function updateModeCards(selectedMode) {
      sectionRoot.querySelectorAll('[data-mode-card]').forEach(function(card) {
        card.classList.remove('is-selected');
      });

      var active = sectionRoot.querySelector('[data-mode-card="' + selectedMode + '"]');
      if (active) active.classList.add('is-selected');
    }

    function updateDisplay() {
      var selectedPack = getSelectedPack();
      var selectedMode = getSelectedMode();
      var quantity = selectedPack ? parseInt(selectedPack.dataset.qty || '1', 10) : 1;
      var packDiscount = selectedPack ? parseFloat(selectedPack.dataset.discount || '0') / 100 : 0;
      var subscribeDiscount = selectedMode === 'subscribe' ? (parseFloat(sectionSettings.subscribeDiscountPercent || 0) / 100) : 0;
      var baseTotal = Math.round(basePrice * quantity);
      var compareBaseTotal = Math.round(baseCompareAtPrice * quantity);
      var afterPackDiscount = Math.round(baseTotal * (1 - packDiscount));
      var total = Math.round(afterPackDiscount * (1 - subscribeDiscount));
      var compareTotal = Math.round(compareBaseTotal * (1 - packDiscount));

      updateModeCards(selectedMode);

      if (selectedPack) {
        sectionRoot.querySelectorAll('.nuumi-calmicollar-hero__pack').forEach(function(card) {
          card.classList.remove('is-selected');
        });
        var selectedCard = selectedPack.closest('.nuumi-calmicollar-hero__pack');
        if (selectedCard) selectedCard.classList.add('is-selected');
      }

      if (quantityInput) quantityInput.value = quantity;
      if (purchaseOptionInput) {
        purchaseOptionInput.value = selectedMode === 'subscribe' ? sectionSettings.subscribeLabel : sectionSettings.oneTimeLabel;
      }
      if (bundleInput && selectedPack) bundleInput.value = selectedPack.dataset.title || '';
      if (priceEl) priceEl.textContent = formatMoney(total);
      if (stickyPriceEl) stickyPriceEl.textContent = formatMoney(total);
      if (atcLabel) {
        atcLabel.textContent = selectedMode === 'subscribe' ? sectionSettings.subscribeCtaLabel : sectionSettings.ctaLabel;
      }
      if (priceNote) {
        priceNote.textContent = selectedMode === 'subscribe' ? sectionSettings.subscribeNote : sectionSettings.oneTimeNote;
      }
      if (comparePriceEl) {
        var shouldShowCompare = baseCompareAtPrice > basePrice && compareTotal > total;
        comparePriceEl.textContent = shouldShowCompare ? formatMoney(compareTotal) : '';
        comparePriceEl.style.display = shouldShowCompare ? 'block' : 'none';
      }
      if (priceChip) {
        priceChip.textContent = selectedMode === 'subscribe' ? sectionSettings.subscribeBadge : sectionSettings.oneTimeBadge;
        priceChip.style.display = priceChip.textContent ? 'inline-flex' : 'none';
      }
      if (ctaNote) {
        ctaNote.textContent = selectedMode === 'subscribe' ? sectionSettings.subscribeCtaNote : sectionSettings.oneTimeCtaNote;
      }

      if (stickyButton) {
        stickyButton.textContent = selectedMode === 'subscribe' ? sectionSettings.subscribeCtaLabel : sectionSettings.stickyLabel;
      }

      packInputs.forEach(function(input) {
        var card = input.closest('.nuumi-calmicollar-hero__pack');
        if (!card) return;

        var packQty = parseInt(input.dataset.qty || '1', 10);
        var packLevelDiscount = parseFloat(input.dataset.discount || '0') / 100;
        var packBaseTotal = Math.round(basePrice * packQty);
        var packOneTime = Math.round(packBaseTotal * (1 - packLevelDiscount));
        var packFinal = Math.round(packOneTime * (1 - subscribeDiscount));
        var perBottle = Math.round(packFinal / Math.max(packQty, 1));
        var savings = Math.max(packBaseTotal - packFinal, 0);

        var perNode = card.querySelector('[data-pack-per]');
        var saveNode = card.querySelector('[data-pack-save]');

        if (perNode) perNode.textContent = formatMoney(perBottle) + '/bottle';
        if (saveNode) {
          saveNode.textContent = savings > 0 ? 'Save ' + formatMoney(savings) : '';
          saveNode.style.display = savings > 0 ? 'inline-flex' : 'none';
        }
      });
    }

    packInputs.forEach(function(input) {
      input.addEventListener('change', updateDisplay);
    });

    modeInputs.forEach(function(input) {
      input.addEventListener('change', updateDisplay);
    });

    if (stickyButton && submitButton) {
      stickyButton.addEventListener('click', function() {
        submitButton.click();
      });
    }

    if (stickyCta && buyCard) {
      var syncStickyCta = function() {
        var rect = buyCard.getBoundingClientRect();
        var shouldShow = rect.bottom <= 0;
        stickyCta.classList.toggle('nuumi-sticky-cta--visible', shouldShow);
      };

      var observer = new IntersectionObserver(function() {
        syncStickyCta();
      }, { threshold: [0, 1] });

      observer.observe(buyCard);
      window.addEventListener('scroll', syncStickyCta, { passive: true });
      window.addEventListener('resize', syncStickyCta);
      syncStickyCta();
    }

    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined' && PUB_SUB_EVENTS.variantChange) {
      subscribe(PUB_SUB_EVENTS.variantChange, function(event) {
        var payload = event && event.data ? event.data : null;
        if (!payload || payload.sectionId !== '{{ section.id }}' || !payload.variant) return;

        basePrice = payload.variant.price || basePrice;
        baseCompareAtPrice = payload.variant.compare_at_price || 0;
        updateDisplay();
      });
    }

    updateDisplay();
  });
</script>

{% schema %}
{
  "name": "Nuumi CalmiCollar Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "checkbox", "id": "enable_sticky_cta", "label": "Enable mobile sticky CTA", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Comfort-first calm support for anxious dogs" },
    { "type": "text", "id": "badge_primary", "label": "Primary badge", "default": "Vet Approved" },
    { "type": "text", "id": "badge_secondary", "label": "Secondary badge", "default": "100% Drug-Free" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Make Your Dog Stop Barking Non-Stop, Peeing Indoors, or Destroying Furniture When Left Alone." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "The maternal secret that gives your dog safety in a collar. Provides 24/7 calming relief without turning your dog into a zombie." },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>CalmiCollar helps interrupt fence fighting, delivery-driver barking, and frantic jumping or nipping with a faster, lower-friction tool that is easy to keep nearby.</p>" },
    { "type": "range", "id": "rating_value", "label": "Rating", "min": 0, "max": 5, "step": 0.1, "default": 4.8 },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "4,100+" },
    { "type": "text", "id": "rating_caption", "label": "Rating caption", "default": "Calmer homes" },
    { "type": "text", "id": "price_label", "label": "Price label", "default": "Choose your calming plan" },
    { "type": "text", "id": "purchase_mode_heading", "label": "Purchase mode heading", "default": "Choose your bundle" },
    { "type": "text", "id": "purchase_microcopy", "label": "Purchase microcopy", "default": "4,100+ transformed dog owners" },
    { "type": "text", "id": "one_time_label", "label": "One-time label", "default": "One-Time Purchase" },
    { "type": "text", "id": "one_time_mode_text", "label": "One-time mode text", "default": "Pay once, no subscription" },
    { "type": "text", "id": "one_time_note", "label": "Price note", "default": "One-time purchase. No hidden fees." },
    { "type": "text", "id": "one_time_badge", "label": "Price badge", "default": "One-Time Purchase" },
    { "type": "checkbox", "id": "enable_subscribe_mode", "label": "Enable subscribe option", "default": false },
    { "type": "range", "id": "subscribe_discount_percent", "label": "Subscribe discount (%)", "min": 0, "max": 40, "step": 1, "default": 20 },
    { "type": "text", "id": "subscribe_label", "label": "Subscribe label", "default": "Subscribe & Save" },
    { "type": "text", "id": "subscribe_badge", "label": "Subscribe badge", "default": "Save 20%" },
    { "type": "text", "id": "subscribe_note", "label": "Subscribe note", "default": "Lower monthly cost. Skip or cancel anytime." },
