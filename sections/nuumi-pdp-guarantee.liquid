{{ 'nuumi-pdp.css' | asset_url | stylesheet_tag }}

<div class="nuumi-guarantee section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-guarantee__container">
      {% render 'nuumi-icon-media', icon_source: section.settings.icon_source, icon: section.settings.icon, custom_svg: section.settings.custom_svg, image: section.settings.custom_image, wrapper_class: 'nuumi-guarantee__icon-wrapper', icon_class: 'nuumi-guarantee__icon', image_width: 112, image_sizes: '56px', image_widths: '56, 84, 112', alt: section.settings.title %}
      <div class="nuumi-guarantee__content">
        <h2 class="nuumi-guarantee__title">{{ section.settings.title }}</h2>
        <div class="nuumi-guarantee__text">{{ section.settings.text }}</div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Nuumi Guarantee",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#1E3A8A"
    },
    {
      "type": "select",
      "id": "icon_source",
      "label": "Icon Source",
      "options": [
        { "value": "icon", "label": "Theme Icon" },
        { "value": "svg", "label": "Custom SVG" },
        { "value": "image", "label": "Image" }
      ],
      "default": "icon"
    },
    {
      "type": "select",
      "id": "icon",
      "label": "Icon",
      "options": [
        { "value": "paw", "label": "Paw" },
        { "value": "science", "label": "Science" },
        { "value": "shield", "label": "Shield" },
        { "value": "check_mark", "label": "Check Mark" },
        { "value": "star", "label": "Star" },
        { "value": "truck", "label": "Truck" },
        { "value": "return", "label": "Return" },
        { "value": "leaf", "label": "Leaf" },
        { "value": "heart", "label": "Heart" }
      ],
      "default": "shield"
    },
    {
      "type": "textarea",
      "id": "custom_svg",
      "label": "Custom SVG Markup"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Custom Image"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Our 90-Day Promise"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>If you or your pet aren't 100% satisfied with the results, we'll refund your purchase. No questions asked.</p>"
    }
  ],
  "presets": [
    {
      "name": "Nuumi Guarantee"
    }
  ]
}
{% endschema %}
