{%- style -%}
  .nuumi-announcement-bar {
    background-color: {{ section.settings.bg_color }};
    color: #FFFFFF;
    text-align: center;
    padding: 0.8rem 1.5rem;
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    font-weight: 500;
    line-height: 1.2;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 40px;
  }
  .nuumi-announcement-bar__link {
    color: inherit;
    text-decoration: none;
    display: block;
    width: 100%;
  }
  .nuumi-announcement-bar__text {
    margin: 0;
  }
{%- endstyle -%}

<div class="nuumi-announcement-bar" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" class="nuumi-announcement-bar__link">
  {%- endif -%}
    <p class="nuumi-announcement-bar__text">
      {{ section.settings.text | escape }}
    </p>
  {%- if section.settings.link != blank -%}
    </a>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Nuumi Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free Shipping on Orders Over $75"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Announcement link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0A1B32"
    }
  ],
  "presets": [
    {
      "name": "Nuumi Announcement Bar"
    }
  ]
}
{% endschema %}
