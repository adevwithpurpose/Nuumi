{%- liquid
  assign announcement_enabled = true
  assign announcement_text = section.settings.text
  assign announcement_link = section.settings.link
  assign announcement_bg = section.settings.bg_color

  if section.settings.use_global_content and settings.nuumi_announcement_use_global
    assign announcement_enabled = settings.nuumi_announcement_enabled
    assign announcement_text = settings.nuumi_announcement_text
    assign announcement_link = settings.nuumi_announcement_link
    assign announcement_bg = settings.nuumi_announcement_bg
  endif
-%}

{%- if announcement_enabled and announcement_text != blank -%}
{%- style -%}
  .nuumi-announcement-bar {
    background-color: {{ announcement_bg }};
    color: #FFFFFF;
    text-align: center;
    padding: 0.8rem 1.5rem;
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    font-weight: 500;
    line-height: 1.2;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 40px;
  }
  .nuumi-announcement-bar__link {
    color: inherit;
    text-decoration: none;
    display: block;
    width: 100%;
  }
  .nuumi-announcement-bar__text {
    margin: 0;
  }
{%- endstyle -%}

<div class="nuumi-announcement-bar" role="region" aria-label="{{ 'sections.header.announcement' | t }}">
  {%- if announcement_link != blank -%}
    <a href="{{ announcement_link }}" class="nuumi-announcement-bar__link">
  {%- endif -%}
    <p class="nuumi-announcement-bar__text">
      {{ announcement_text | escape }}
    </p>
  {%- if announcement_link != blank -%}
    </a>
  {%- endif -%}
</div>
{%- endif -%}

{% schema %}
{
  "name": "Nuumi Announcement Bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_global_content",
      "label": "Use global announcement settings",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free Shipping on Orders Over $75"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Announcement link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#0A1B32"
    }
  ],
  "presets": [
    {
      "name": "Nuumi Announcement Bar"
    }
  ]
}
{% endschema %}
