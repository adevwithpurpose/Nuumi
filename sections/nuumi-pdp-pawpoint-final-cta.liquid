<div class="nuumi-pawpoint-final-cta section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-pawpoint-final-cta__inner">
      {%- if section.settings.eyebrow != blank -%}
        <span class="nuumi-pawpoint-final-cta__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="nuumi-pawpoint-final-cta__title">{{ section.settings.title }}</h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="nuumi-pawpoint-final-cta__subtitle">{{ section.settings.subtitle }}</p>
      {%- endif -%}

      {%- if section.settings.media_image != blank -%}
        <div class="nuumi-pawpoint-final-cta__media">
          {{ section.settings.media_image | image_url: width: 800 | image_tag:
            loading: 'lazy',
            class: 'nuumi-pawpoint-final-cta__media-image',
            widths: '400, 600, 800'
          }}
        </div>
      {%- endif -%}

      <div class="nuumi-pawpoint-final-cta__trust">
        {%- if section.settings.show_guarantee -%}
          <div class="nuumi-pawpoint-final-cta__trust-item">
            {% render 'nuumi-icons', icon: 'shield' %}
            <span>{{ section.settings.guarantee_text }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.show_shipping -%}
          <div class="nuumi-pawpoint-final-cta__trust-item">
            {% render 'nuumi-icons', icon: 'truck' %}
            <span>{{ section.settings.shipping_text }}</span>
          </div>
        {%- endif -%}
        {%- if section.settings.show_payment -%}
          <div class="nuumi-pawpoint-final-cta__trust-item">
            {% render 'nuumi-icons', icon: 'return' %}
            <span>{{ section.settings.payment_text }}</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Nuumi PawPoint Final CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Start today" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Give Your Dog's Ears the Care They Actually Need." },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Join thousands of pet parents who finally stopped the head shaking and ear scratching for good." },
    { "type": "image_picker", "id": "media_image", "label": "Hero Image (optional)" },
    { "type": "checkbox", "id": "show_guarantee", "label": "Show guarantee badge", "default": true },
    { "type": "text", "id": "guarantee_text", "label": "Guarantee text", "default": "30-Day Money-Back Guarantee" },
    { "type": "checkbox", "id": "show_shipping", "label": "Show shipping badge", "default": true },
    { "type": "text", "id": "shipping_text", "label": "Shipping text", "default": "Fast US Shipping" },
    { "type": "checkbox", "id": "show_payment", "label": "Show payment badge", "default": true },
    { "type": "text", "id": "payment_text", "label": "Payment text", "default": "Secure Checkout" }
  ],
  "presets": [
    {
      "name": "Nuumi PawPoint Final CTA"
    }
  ]
}
{% endschema %}
