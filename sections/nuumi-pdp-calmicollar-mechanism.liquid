{{ 'nuumi-pdp.css' | asset_url | stylesheet_tag }}

<div class="nuumi-pdp-mechanism section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-pdp-mechanism__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-pdp-mechanism__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="nuumi-pdp-mechanism__title">{{ section.settings.title }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <div class="nuumi-pdp-mechanism__text">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-pdp-mechanism__grid">
      {%- for block in section.blocks -%}
        <article class="nuumi-pdp-mechanism__card" {{ block.shopify_attributes }}>
          {% render 'nuumi-icon-media', icon_source: block.settings.icon_source, icon: block.settings.icon, custom_svg: block.settings.custom_svg, image: block.settings.custom_image, wrapper_class: 'nuumi-pdp-mechanism__icon', icon_class: 'nuumi-pdp-mechanism__icon', image_width: 96, image_sizes: '48px', image_widths: '48, 72, 96', alt: block.settings.title %}
          <h3 class="nuumi-pdp-mechanism__card-title">{{ block.settings.title }}</h3>
          <div class="nuumi-pdp-mechanism__card-text">{{ block.settings.text }}</div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CalmiCollar Science",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#F7FBFD" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "The Science of Pheromones" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Why NeuroEase Blend calms the brain before behavior spirals." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>A dual-signal pheromone approach built to reduce outside fear signals while increasing internal feelings of safety.</p>" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 2,
      "settings": [
        {
          "type": "select",
          "id": "icon_source",
          "label": "Icon Source",
          "options": [
            { "value": "icon", "label": "Theme Icon" },
            { "value": "svg", "label": "Custom SVG" },
            { "value": "image", "label": "Image" }
          ],
          "default": "icon"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" },
            { "value": "check_mark", "label": "Check Mark" }
          ],
          "default": "science"
        },
        { "type": "textarea", "id": "custom_svg", "label": "Custom SVG Markup" },
        { "type": "image_picker", "id": "custom_image", "label": "Custom Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "CAP" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Tells the brain everything is fine here by helping block outside fear signals.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CalmiCollar Science",
      "blocks": [
        { "type": "feature", "settings": { "icon_source": "icon", "icon": "science", "title": "CAP", "text": "<p>Tells the brain everything is fine here by helping block outside fear signals.</p>" } },
        { "type": "feature", "settings": { "icon_source": "icon", "icon": "heart", "title": "MAP", "text": "<p>Mimics the mother-dog signal that says you are safe, calming internal stress and panic.</p>" } }
      ]
    }
  ]
}
{% endschema %}
