{{ 'nuumi-pdp.css' | asset_url | stylesheet_tag }}

<div class="nuumi-pdp-expert-modern section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width page-width--narrow">
    <div class="nuumi-pdp-expert-modern__card">
      <div class="nuumi-pdp-expert-modern__image-column">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 800 | image_tag:
            loading: 'lazy',
            class: 'nuumi-pdp-expert-modern__image',
            sizes: '(min-width: 750px) 40vw, 100vw',
            widths: '375, 550, 750, 800'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg nuumi-pdp-expert-modern__image' }}
        {%- endif -%}
      </div>
      <div class="nuumi-pdp-expert-modern__content-column">
        {%- if section.settings.badge_text != blank -%}
          <div class="nuumi-pdp-expert-modern__badge">{{ section.settings.badge_text }}</div>
        {%- endif -%}
        
        {%- if section.settings.quote != blank -%}
          <h3 class="nuumi-pdp-expert-modern__quote">"{{ section.settings.quote }}"</h3>
        {%- endif -%}
        
        <div class="nuumi-pdp-expert-modern__footer">
          <div class="nuumi-pdp-expert-modern__author">
            {%- if section.settings.name != blank -%}
              <span class="nuumi-pdp-expert-modern__name">{{ section.settings.name }}</span>
            {%- endif -%}
            {%- if section.settings.credentials != blank -%}
              <span class="nuumi-pdp-expert-modern__credentials">{{ section.settings.credentials }}</span>
            {%- endif -%}
          </div>

          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" target="_blank" class="nuumi-pdp-expert-modern__insta" aria-label="Follow on Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Nuumi Expert (Modern)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f9f9"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Expert Image"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Veterinary Perspective"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "When a dog keeps cycling through diarrhea, itching, and immune stress, I want a formula that supports the intestinal barrier itself. That is what makes the protocol feel clinically coherent instead of symptom-chasing."
    },
    {
      "type": "text",
      "id": "name",
      "label": "Expert Name",
      "default": "Dr. Sara Ranocchi"
    },
    {
      "type": "text",
      "id": "credentials",
      "label": "Credentials",
      "default": "Italian Nutrition Biologist"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram Link",
      "default": "https://www.instagram.com/dr.sara_ranocchi_/"
    }
  ],
  "presets": [
    {
      "name": "Nuumi Expert (Modern)"
    }
  ]
}
{% endschema %}
