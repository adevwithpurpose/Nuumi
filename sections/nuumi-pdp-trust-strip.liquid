{{ 'nuumi-pdp.css' | asset_url | stylesheet_tag }}

<div class="nuumi-trust-strip section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-trust-strip__grid">
      {%- for block in section.blocks -%}
        <div class="nuumi-trust-strip__item" {{ block.shopify_attributes }}>
          {% render 'nuumi-icon-media', icon_source: block.settings.icon_source, icon: block.settings.icon, custom_svg: block.settings.custom_svg, image: block.settings.custom_image, wrapper_class: 'nuumi-trust-strip__icon', icon_class: 'nuumi-trust-strip__icon', image_width: 64, image_sizes: '32px', image_widths: '32, 48, 64', alt: block.settings.text %}
          <span class="nuumi-trust-strip__text">{{ block.settings.text }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Nuumi Trust Strip",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9FAFB"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon_source",
          "label": "Icon Source",
          "options": [
            { "value": "icon", "label": "Theme Icon" },
            { "value": "svg", "label": "Custom SVG" },
            { "value": "image", "label": "Image" }
          ],
          "default": "icon"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "paw", "label": "Paw" },
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "check_mark", "label": "Check Mark" },
            { "value": "star", "label": "Star" },
            { "value": "truck", "label": "Truck" },
            { "value": "return", "label": "Return" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "shield"
        },
        { "type": "textarea", "id": "custom_svg", "label": "Custom SVG Markup" },
        { "type": "image_picker", "id": "custom_image", "label": "Custom Image" },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust Point"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Trust Strip",
      "blocks": [
        { "type": "trust_item", "settings": { "icon": "truck", "text": "Free US Shipping" } },
        { "type": "trust_item", "settings": { "icon": "science", "text": "Vet Formulated" } },
        { "type": "trust_item", "settings": { "icon": "shield", "text": "90-Day Guarantee" } },
        { "type": "trust_item", "settings": { "icon": "leaf", "text": "All Natural" } }
      ]
    }
  ]
}
{% endschema %}
