<div class="nuumi-pdp-social-proof section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-pdp-social-proof__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-pdp-social-proof__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2 class="nuumi-pdp-social-proof__title">{{ section.settings.title }}</h2>
      <div class="nuumi-pdp-social-proof__text rte">{{ section.settings.text }}</div>
    </div>

    {%- assign has_videos = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'video' -%}{%- assign has_videos = true -%}{%- break -%}{%- endif -%}
    {%- endfor -%}

    {%- if has_videos -%}
      <div class="nuumi-pdp-social-proof__video-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'video' -%}
            {%- assign video_id = block.settings.video.id | default: block.settings.video_url.id -%}
            <div class="nuumi-pdp-social-proof__video-card" {{ block.shopify_attributes }}>
              <div class="nuumi-pdp-social-proof__video-frame">
                {%- if block.settings.poster_image != blank -%}
                  <button
                    type="button"
                    class="nuumi-pdp-social-proof__video-placeholder"
                    data-video-toggle
                    aria-label="Play video: {{ block.settings.title | escape }}"
                  >
                    {{ block.settings.poster_image | image_url: width: 1200 | image_tag:
                      loading: 'lazy',
                      class: 'nuumi-pdp-social-proof__poster-image',
                      sizes: '(min-width: 990px) 400px, 100vw',
                      widths: '400, 600, 800, 1000, 1200'
                    }}
                    <div class="nuumi-pdp-social-proof__play-overlay">
                      <span class="nuumi-pdp-social-proof__play-badge">
                        <svg class="nuumi-pdp-social-proof__play-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M8 5v14l11-7z"/>
                        </svg>
                      </span>
                    </div>
                  </button>
                  <div class="nuumi-pdp-social-proof__video-player" hidden>
                {%- endif -%}

                {%- if block.settings.video != blank -%}
                  {{ block.settings.video | video_tag: controls: true, autoplay: false, loop: false, muted: false, class: 'nuumi-pdp-social-proof__video-media', preload: 'metadata' }}
                {%- elsif block.settings.video_url != blank and video_id != blank -%}
                  {%- if block.settings.video_url.type == 'youtube' -%}
                    <iframe
                      class="nuumi-pdp-social-proof__video-media"
                      src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&rel=0&modestbranding=1"
                      allow="autoplay; encrypted-media; picture-in-picture"
                      allowfullscreen
                      title="{{ block.settings.title | escape }}"
                      loading="lazy"
                    ></iframe>
                  {%- else -%}
                    <iframe
                      class="nuumi-pdp-social-proof__video-media"
                      src="https://player.vimeo.com/video/{{ video_id }}?title=0&byline=0&portrait=0"
                      allow="autoplay; encrypted-media; picture-in-picture"
                      allowfullscreen
                      title="{{ block.settings.title | escape }}"
                      loading="lazy"
                    ></iframe>
                  {%- endif -%}
                {%- else -%}
                  <svg class="nuumi-pdp-social-proof__play-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8"></polygon></svg>
                {%- endif -%}

                {%- if block.settings.poster_image != blank -%}
                  </div>
                {%- endif -%}
              </div>
              {%- if block.settings.title != blank -%}
                <p class="nuumi-pdp-social-proof__video-title">{{ block.settings.title }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="nuumi-pdp-social-proof__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'review' -%}
          <article class="nuumi-pdp-social-proof__card" {{ block.shopify_attributes }}>
            <div class="nuumi-pdp-social-proof__card-top">
              {% render 'nuumi-rating-stars', rating: block.settings.rating, count: blank, class: 'nuumi-pdp-social-proof__stars' %}
              {%- if block.settings.badge != blank -%}
                <span class="nuumi-pdp-social-proof__badge">{{ block.settings.badge }}</span>
              {%- endif -%}
            </div>
            <blockquote class="nuumi-pdp-social-proof__quote">{{ block.settings.quote }}</blockquote>
            <p class="nuumi-pdp-social-proof__highlight">{{ block.settings.highlight }}</p>
            <div class="nuumi-pdp-social-proof__author">
              <span class="nuumi-pdp-social-proof__name">{{ block.settings.name }}</span>
              {%- if block.settings.meta != blank -%}
                <span class="nuumi-pdp-social-proof__meta">{{ block.settings.meta }}</span>
              {%- endif -%}
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Nuumi Social Proof",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#FFFFFF" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Real family proof" },
    { "type": "text", "id": "title", "label": "Heading", "default": "The reviews all sound the same: finally, the stool settled and the itching started backing off." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>These cards are written to feel like the relief pet parents are actually chasing: less mess, less scratching, and fewer desperate swings from one failed fix to the next.</p>" }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video Placeholder",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "poster_image", "label": "Poster image" },
        { "type": "video", "id": "video", "label": "Shopify-hosted video" },
        { "type": "video_url", "id": "video_url", "accept": ["youtube", "vimeo"], "label": "External video URL", "placeholder": "https://www.youtube.com/watch?v=_9VUPq3SxOc", "info": "Use YouTube or Vimeo if the video is not uploaded to Shopify." },
        { "type": "text", "id": "title", "label": "Label/Title", "default": "Watch our story" }
      ]
    },
    {
      "type": "review",
      "name": "Review",
      "limit": 4,
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Verified Buyer" },
        { "type": "textarea", "id": "quote", "label": "Quote", "default": "After months of messy stools and vet visits, EnerCanis was the first thing that actually made the pattern start calming down." },
        { "type": "text", "id": "highlight", "label": "Highlight", "default": "Firmer stools in the first week." },
        { "type": "text", "id": "name", "label": "Name", "default": "Melissa R." },
        { "type": "text", "id": "meta", "label": "Meta", "default": "French bulldog parent" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Social Proof",
      "blocks": [
        { "type": "video", "settings": { "title": "How it works" } },
        { "type": "video", "settings": { "title": "Real results" } },
        { "type": "video", "settings": { "title": "Why EnerCanis?" } },
        { "type": "review", "settings": { "rating": 5, "badge": "Verified Buyer", "quote": "We tried prescription food, powders, and rotating probiotics. EnerCanis was the first thing that made his stool look normal and his skin stop flaring every few days.", "highlight": "Visible change by week two.", "name": "Melissa R.", "meta": "English bulldog parent" } },
        { "type": "review", "settings": { "rating": 5, "badge": "Photo Review", "quote": "The biggest difference was how quickly the gut chaos settled. Once that happened, the itching and redness also started improving instead of staying in a constant cycle.", "highlight": "Less itching, better stools.", "name": "Andre T.", "meta": "Rescue mix parent" } },
        { "type": "review", "settings": { "rating": 5, "badge": "Most Helpful", "quote": "The 3-bottle plan made the difference for us. One bottle was encouraging, but by the full supply window it really felt like his old chronic pattern had broken.", "highlight": "3-bottle protocol felt worth it.", "name": "Jasmine L.", "meta": "Senior dog parent" } }
      ]
    }
  ]
}
{% endschema %}

<script>
  document.addEventListener('click', function(event) {
    var trigger = event.target.closest('[data-video-toggle]');
    if (!trigger) return;

    var frame = trigger.closest('.nuumi-pdp-social-proof__video-frame');
    if (!frame) return;

    var player = frame.querySelector('.nuumi-pdp-social-proof__video-player');
    if (!player) return;

    trigger.hidden = true;
    player.hidden = false;

    var media = player.querySelector('video');
    if (media) {
      media.play().catch(function() {});
    }
  });
</script>
