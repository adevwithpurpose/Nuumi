{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nuumi-section nuumi-product-page nuumi-product-benefits section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-section-header">
      {%- if section.settings.eyebrow != blank -%}<p class="nuumi-kicker">{{ section.settings.eyebrow }}</p>{%- endif -%}
      <h2 class="nuumi-section-heading">{{ section.settings.heading }}</h2>
      <div class="nuumi-product-story__body rte">{{ section.settings.intro }}</div>
    </div>
    <div class="nuumi-product-benefits__grid">
      {%- for block in section.blocks -%}
        <article class="nuumi-product-benefit-card" {{ block.shopify_attributes }}>
          <span class="nuumi-proof-card__icon">{% render 'nuumi-icons', icon: block.settings.icon %}</span>
          <span class="nuumi-product-benefit-card__eyebrow">{{ block.settings.eyebrow }}</span>
          <h3 class="nuumi-product-benefit-card__title">{{ block.settings.title }}</h3>
          <div class="nuumi-product-benefit-card__text rte">{{ block.settings.text }}</div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Benefits",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Benefits and features" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Turn the formulation into clear, believable customer benefits" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>Use concise cards here to explain the practical outcomes and support ingredients without overwhelming the product page.</p>" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Top padding", "default": 12 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Bottom padding", "default": 48 }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 6,
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "science", "label": "Science" }, { "value": "shield", "label": "Shield" }, { "value": "heart", "label": "Heart" }, { "value": "paw", "label": "Paw" }, { "value": "check", "label": "Check" }], "default": "science" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Benefit" },
        { "type": "text", "id": "title", "label": "Title", "default": "Supportive, easy-to-read benefit" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Keep this grounded in what the customer can understand and what the product is truly meant to support.</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "Nuumi Benefits", "blocks": [{ "type": "benefit" }, { "type": "benefit" }, { "type": "benefit" }] }
  ]
}
{% endschema %}
