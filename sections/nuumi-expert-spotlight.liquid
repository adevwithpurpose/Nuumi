{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nuumi-section nuumi-expert-spotlight section-{{ section.id }}-padding">
  <div class="page-width nuumi-home-reveal">
    <div class="nuumi-expert-spotlight__grid">
      <div class="nuumi-expert-spotlight__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              widths: '533, 720, 900, 1200',
              loading: 'lazy',
              sizes: '(min-width: 990px) 45vw, 100vw'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div class="nuumi-expert-spotlight__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="nuumi-kicker">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        <h2 class="nuumi-section-heading">{{ section.settings.heading }}</h2>

        {%- if section.settings.body != blank -%}
          <div class="nuumi-expert-spotlight__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        <div class="nuumi-expert-spotlight__quote-card">
          <span class="nuumi-expert-spotlight__quote-mark">{% render 'nuumi-icons', icon: 'quote' %}</span>
          <p class="nuumi-expert-spotlight__quote">{{ section.settings.quote }}</p>
          <div>
            <p class="nuumi-expert-spotlight__name">{{ section.settings.name }}</p>
            <p class="nuumi-expert-spotlight__role">{{ section.settings.role }}</p>
          </div>
        </div>

        {%- if section.blocks.size > 0 -%}
          <ul class="nuumi-expert-spotlight__proof-list" role="list">
            {%- for block in section.blocks -%}
              <li class="nuumi-expert-spotlight__proof-item" {{ block.shopify_attributes }}>
                <span class="nuumi-proof-card__icon">{% render 'nuumi-icons', icon: block.settings.icon %}</span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div class="nuumi-home-button-row">
            <a class="nuumi-home-button nuumi-home-button--ghost" href="{{ section.settings.button_link | default: '#' }}">{{ section.settings.button_label }}</a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumipet Expert Spotlight",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Expert-led trust"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Guided by professionals who care about credibility, not clutter"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Use this section to introduce the veterinarian, specialist, or scientific voice behind the brand. Keep it concise, human, and reassuring.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Expert image"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "When pet parents understand what they are giving their dog and why it works, trust follows naturally."
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "Dr. Nuumi Expert"
    },
    {
      "type": "text",
      "id": "role",
      "label": "Role",
      "default": "Veterinary Advisor"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Read the science"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "proof_point",
      "name": "Proof point",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Check" },
            { "value": "shield", "label": "Shield" },
            { "value": "science", "label": "Science" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Backed by a clear rationale and easy-to-understand ingredients."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumipet Expert Spotlight",
      "blocks": [
        { "type": "proof_point" },
        { "type": "proof_point" },
        { "type": "proof_point" }
      ]
    }
  ]
}
{% endschema %}
