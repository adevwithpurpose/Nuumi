{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-expert-spotlight section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-expert-spotlight__panel">
      <div class="nuumi-expert-spotlight__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag:
            class: 'nuumi-expert-spotlight__image',
            loading: 'lazy',
            widths: '400, 600, 900, 1200',
            alt: section.settings.name | escape
          }}
        {%- else -%}
          <div class="nuumi-expert-spotlight__image-placeholder">
            {% render 'nuumi-icons', icon: 'science', class: 'nuumi-expert-spotlight__placeholder-icon' %}
          </div>
        {%- endif -%}
      </div>

      <div class="nuumi-expert-spotlight__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="nuumi-expert-spotlight__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="nuumi-expert-spotlight__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.quote != blank -%}
          <blockquote class="nuumi-expert-spotlight__quote">
            <p>"{{ section.settings.quote | escape }}"</p>
          </blockquote>
        {%- endif -%}

        <div class="nuumi-expert-spotlight__credentials">
          {%- if section.settings.name != blank -%}
            <p class="nuumi-expert-spotlight__name">{{ section.settings.name | escape }}</p>
          {%- endif -%}
          {%- if section.settings.role != blank -%}
            <p class="nuumi-expert-spotlight__role">{{ section.settings.role | escape }}</p>
          {%- endif -%}
        </div>

        {%- if section.settings.body != blank -%}
          <div class="nuumi-expert-spotlight__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="nuumi-expert-spotlight__points" role="list">
            {%- for block in section.blocks -%}
              <li class="nuumi-expert-spotlight__point" {{ block.shopify_attributes }}>
                {% render 'nuumi-icons', icon: block.settings.icon, class: 'nuumi-expert-spotlight__point-icon' %}
                <div>
                  {%- if block.settings.title != blank -%}
                    <p class="nuumi-expert-spotlight__point-title">{{ block.settings.title | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p class="nuumi-expert-spotlight__point-text">{{ block.settings.text | escape }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Expert Spotlight",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "A clearer product philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built for everyday pet issues, not generic wellness buzzwords."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Expert image"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "A strong pet-wellness routine should make it obvious what to reach for first, what each product is helping with, and how the pieces fit together at home."
    },
    {
      "type": "text",
      "id": "name",
      "label": "Name",
      "default": "Why Nuumipet stays focused"
    },
    {
      "type": "text",
      "id": "role",
      "label": "Role",
      "default": "Targeted wellness essentials"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>The range stays lean: EnerCanis for gut support, ByeBark for bark control, CalmiCollar for calming support, PawPoint for ear hygiene, and one bundle for homes that want broader coverage.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "proof_point",
      "name": "Proof point",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "check_mark", "label": "Check mark" },
            { "value": "paw", "label": "Paw" }
          ],
          "default": "science"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Specific jobs"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "The lineup is built around real needs like gut health, calming support, bark control, and ear cleaning."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Expert Spotlight",
      "blocks": [
        { "type": "proof_point" },
         { "type": "proof_point", "settings": { "icon": "shield", "title": "Measured claims", "text": "The homepage stays grounded in what each product is actually designed to do instead of promising everything at once." } },
         { "type": "proof_point", "settings": { "icon": "heart", "title": "Routine friendly", "text": "Each essential is positioned to feel realistic for everyday use, whether it is a supplement, collar, device, wipe, or bundle." } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
