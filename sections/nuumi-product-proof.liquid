{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nuumi-section nuumi-product-page nuumi-product-proof section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-product-proof__grid">
      <div class="nuumi-product-proof__expert">
        <div class="nuumi-product-proof__expert-grid">
          <div class="nuumi-product-proof__expert-image">
            {%- if section.settings.image != blank -%}
              {{ section.settings.image | image_url: width: 1200 | image_tag: widths: '720, 960, 1200', sizes: '(min-width: 990px) 30vw, 100vw', loading: 'lazy' }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div>
            {%- if section.settings.eyebrow != blank -%}<p class="nuumi-kicker">{{ section.settings.eyebrow }}</p>{%- endif -%}
            <h2 class="nuumi-section-heading">{{ section.settings.heading }}</h2>
            <div class="nuumi-product-proof__intro rte">{{ section.settings.intro }}</div>
            <p class="nuumi-product-proof__quote">{{ section.settings.quote }}</p>
            <p class="nuumi-product-proof__quote-author">{{ section.settings.expert_name }}</p>
            <p class="nuumi-product-proof__quote-role">{{ section.settings.expert_role }}</p>
          </div>
        </div>
        <ul class="nuumi-product-proof__checks" role="list">
          {%- for index in (1..3) -%}
            {%- capture key -%}check_{{ index }}{%- endcapture -%}
            {%- assign text = section.settings[key] -%}
            {%- if text != blank -%}
              <li><span class="nuumi-proof-card__icon">{% render 'nuumi-icons', icon: 'check' %}</span><span>{{ text }}</span></li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
      <div class="nuumi-product-proof__cards">
        {%- for block in section.blocks -%}
          <article class="nuumi-product-proof-card" {{ block.shopify_attributes }}>
            <span class="nuumi-product-proof-card__eyebrow">{{ block.settings.eyebrow }}</span>
            <h3 class="nuumi-product-proof-card__title">{{ block.settings.title }}</h3>
            <div class="nuumi-product-proof-card__text rte">{{ block.settings.text }}</div>
            {%- if block.settings.image != blank -%}
              <div class="nuumi-product-proof-card__image">
                {{ block.settings.image | image_url: width: 900 | image_tag: widths: '320, 533, 900', sizes: '(min-width: 990px) 30vw, 100vw', loading: 'lazy' }}
              </div>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Product Proof",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Proof and trust" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Layer in expert reassurance, proof, and customer confidence" },
    { "type": "richtext", "id": "intro", "label": "Intro", "default": "<p>This section should combine social proof, expert authority, and operational trust without feeling noisy.</p>" },
    { "type": "textarea", "id": "quote", "label": "Quote", "default": "This is where the product page earns trust by connecting clear formulation logic with the customer's real routine." },
    { "type": "text", "id": "expert_name", "label": "Expert name", "default": "Dr. Nuumi Expert" },
    { "type": "text", "id": "expert_role", "label": "Expert role", "default": "Veterinary Advisor" },
    { "type": "image_picker", "id": "image", "label": "Expert image" },
    { "type": "text", "id": "check_1", "label": "Check 1", "default": "Use this for scientific rationale or formulation clarity." },
    { "type": "text", "id": "check_2", "label": "Check 2", "default": "Use this for quality, sourcing, or support reassurance." },
    { "type": "text", "id": "check_3", "label": "Check 3", "default": "Use this for customer confidence or routine fit." },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Top padding", "default": 12 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Bottom padding", "default": 48 }
  ],
  "blocks": [
    {
      "type": "proof_card",
      "name": "Proof card",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Proof point" },
        { "type": "text", "id": "title", "label": "Title", "default": "Specific trust signal" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use this card for testimonials, testing standards, ingredient clarity, or a concise customer proof point.</p>" },
        { "type": "image_picker", "id": "image", "label": "Optional image" }
      ]
    }
  ],
  "presets": [
    { "name": "Nuumi Product Proof", "blocks": [{ "type": "proof_card" }, { "type": "proof_card" }, { "type": "proof_card" }] }
  ]
}
{% endschema %}
