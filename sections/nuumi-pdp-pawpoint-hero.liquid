<product-info
  id="MainProduct-{{ section.id }}"
  class="nuumi-pdp nuumi-pdp--pawpoint section-{{ section.id }}-padding"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'media-gallery.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>

  {% assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' %}
  {% assign current_variant = product.selected_or_first_available_variant %}
  {% assign base_price = current_variant.price | default: product.price %}
  {% assign base_compare_at_price = current_variant.compare_at_price | default: product.compare_at_price %}
  {% assign has_compare_at_price = false %}
  {% if base_compare_at_price and base_compare_at_price > base_price %}
    {% assign has_compare_at_price = true %}
  {% endif %}
  {% assign pack_blocks = section.blocks | where: 'type', 'pack_option' %}
  {% assign support_blocks = section.blocks | where: 'type', 'support_point' %}
  {% assign first_pack = pack_blocks | first %}
  {% assign default_quantity = first_pack.settings.quantity | default: 1 %}
  {% assign default_bundle_title = first_pack.settings.title | default: '1 Pack' %}
  {% assign one_time_total_price = base_price | times: default_quantity %}
  {% assign one_time_compare_total_price = base_compare_at_price | times: default_quantity %}
  {% assign form_id = 'product-form-' | append: section.id %}
  {% assign subscribe_enabled = false %}

  <div class="page-width">
    <div class="nuumi-pawpoint-hero">
      {% render 'nuumi-hero-gallery',
        variant_images: variant_images,
        section: section,
        shell_class: 'nuumi-pawpoint-hero__media-shell',
        media_column_class: 'nuumi-pawpoint-hero__media-column',
        show_left_guarantee: true,
        left_guarantee_class_prefix: 'nuumi-pawpoint-hero',
        fallback_guarantee_text: '30-Day',
        hide_variants: true
      %}

      <div class="nuumi-pawpoint-hero__content-column">
        <section id="ProductInfo-{{ section.id }}" class="nuumi-pawpoint-hero__panel">
          <div class="nuumi-pawpoint-hero__intro">
            {%- if section.settings.eyebrow != blank -%}
              <p class="nuumi-pawpoint-hero__eyebrow">{{ section.settings.eyebrow }}</p>
            {%- endif -%}

            <div class="nuumi-pawpoint-hero__badge-row">
              {%- if section.settings.badge_primary != blank -%}
                <span class="nuumi-pawpoint-hero__badge">{{ section.settings.badge_primary }}</span>
              {%- endif -%}
              {%- if section.settings.badge_secondary != blank -%}
                <span class="nuumi-pawpoint-hero__badge nuumi-pawpoint-hero__badge--soft">{{ section.settings.badge_secondary }}</span>
              {%- endif -%}
            </div>

            <p class="nuumi-pawpoint-hero__product-name">{{ product.title | escape }}</p>
            <h1 class="nuumi-pawpoint-hero__title">{{ section.settings.headline | default: product.title | escape }}</h1>

            {%- if section.settings.subtitle != blank -%}
              <p class="nuumi-pawpoint-hero__subtitle">{{ section.settings.subtitle }}</p>
            {%- endif -%}

            <div class="nuumi-pawpoint-hero__rating-row">
              {% render 'nuumi-rating-stars', rating: section.settings.rating_value, count: section.settings.review_count, class: 'nuumi-pawpoint-hero__rating' %}
              {%- if section.settings.rating_caption != blank -%}
                <span class="nuumi-pawpoint-hero__rating-caption">{{ section.settings.rating_caption }}</span>
              {%- endif -%}
            </div>

            {%- if section.settings.description != blank -%}
              <div class="nuumi-pawpoint-hero__description rte">{{ section.settings.description }}</div>
            {%- endif -%}
          </div>

          {%- if support_blocks.size > 0 -%}
            <div class="nuumi-pawpoint-hero__support-grid">
              {%- for block in support_blocks -%}
                <article class="nuumi-pawpoint-hero__support-card" {{ block.shopify_attributes }}>
                  {%- if block.settings.image != blank -%}
                    <span class="nuumi-pawpoint-hero__support-media nuumi-pawpoint-hero__support-media--image">
                      {{ block.settings.image | image_url: width: 96 | image_tag:
                        loading: 'lazy',
                        class: 'nuumi-pawpoint-hero__support-image',
                        widths: '48, 72, 96'
                      }}
                    </span>
                  {%- else -%}
                    <span class="nuumi-pawpoint-hero__support-media nuumi-pawpoint-hero__support-media--icon">{% render 'nuumi-icons', icon: block.settings.icon %}</span>
                  {%- endif -%}
                  <div>
                    <p class="nuumi-pawpoint-hero__support-title">{{ block.settings.title }}</p>
                    {%- if block.settings.text != blank -%}
                      <p class="nuumi-pawpoint-hero__support-text">{{ block.settings.text }}</p>
                    {%- endif -%}
                  </div>
                </article>
              {%- endfor -%}
            </div>
          {%- endif -%}

          <div class="nuumi-pawpoint-hero__purchase-card">
            <div class="nuumi-pawpoint-hero__mode-group">
              <p class="nuumi-pawpoint-hero__purchase-label">{{ section.settings.purchase_mode_heading }}</p>
              <div class="nuumi-pawpoint-hero__mode-grid">
                <label class="nuumi-pawpoint-hero__mode {% unless subscribe_enabled %}is-selected{% endunless %}" data-mode-card="one_time">
                  <input
                    type="radio"
                    name="pawpoint_mode_{{ section.id }}"
                    value="one_time"
                    data-mode="one_time"
                    {% unless subscribe_enabled %}checked{% endunless %}
                  >
                  <span class="nuumi-pawpoint-hero__mode-copy">
                    <span class="nuumi-pawpoint-hero__mode-title">{{ section.settings.one_time_label }}</span>
                    <span class="nuumi-pawpoint-hero__mode-text">{{ section.settings.one_time_mode_text }}</span>
                  </span>
                </label>

                  <label class="nuumi-pawpoint-hero__mode is-disabled" data-mode-card="subscribe" aria-disabled="true" title="Subscription option will be enabled after the subscription app is configured.">
                    <input
                      type="radio"
                      name="pawpoint_mode_{{ section.id }}"
                      value="subscribe"
                      data-mode="subscribe"
                      disabled
                    >
                    <span class="nuumi-pawpoint-hero__mode-copy">
                      <span class="nuumi-pawpoint-hero__mode-badge">{{ section.settings.subscribe_badge }}</span>
                      <span class="nuumi-pawpoint-hero__mode-title">{{ section.settings.subscribe_label }}</span>
                      <span class="nuumi-pawpoint-hero__mode-text">Subscription option coming soon once the app is configured.</span>
                    </span>
                    <span class="nuumi-pawpoint-hero__mode-overlay" aria-hidden="true"></span>
                  </label>
              </div>
            </div>

            <div class="nuumi-pawpoint-hero__price-row">
              <div>
                {%- if section.settings.price_label != blank -%}
                  <p class="nuumi-pawpoint-hero__price-label">{{ section.settings.price_label }}</p>
                {%- endif -%}
                <p class="nuumi-pawpoint-hero__price" data-total-price>{{ one_time_total_price | money }}</p>
              </div>
              <div class="nuumi-pawpoint-hero__price-meta">
                {%- if has_compare_at_price -%}
                  <p class="nuumi-pawpoint-hero__compare-at" data-compare-price>{{ one_time_compare_total_price | money }}</p>
                {%- else -%}
                  <p class="nuumi-pawpoint-hero__compare-at" data-compare-price style="display:none"></p>
                {%- endif -%}
                <span class="nuumi-pawpoint-hero__price-chip" data-price-chip>{{ section.settings.one_time_badge }}</span>
                <p class="nuumi-pawpoint-hero__price-note" data-price-note>{{ section.settings.one_time_note }}</p>
              </div>
            </div>

            {%- if pack_blocks.size > 0 -%}
              <div class="nuumi-pawpoint-hero__packs">
                <p class="nuumi-pawpoint-hero__packs-heading">{{ section.settings.pack_heading }}</p>
                <div class="nuumi-pawpoint-hero__pack-grid">
                  {%- for block in pack_blocks -%}
                    {%- assign is_default = false -%}
                    {%- if forloop.first -%}{%- assign is_default = true -%}{%- endif -%}
                    <label class="nuumi-pawpoint-hero__pack {% if is_default %}is-selected{% endif %}" {{ block.shopify_attributes }}>
                      <input
                        type="radio"
                        name="pawpoint_pack_{{ section.id }}"
                        value="{{ block.settings.quantity }}"
                        data-qty="{{ block.settings.quantity }}"
                        data-title="{{ block.settings.title | escape }}"
                        data-discount="{{ block.settings.discount_percent | default: 0 }}"
                        {% if is_default %}checked{% endif %}
                      >
                      {%- if block.settings.badge != blank -%}
                        <span class="nuumi-pawpoint-hero__pack-badge">{{ block.settings.badge }}</span>
                      {%- endif -%}
                      <span class="nuumi-pawpoint-hero__pack-title">{{ block.settings.title }}</span>
                      {%- if block.settings.subtitle != blank -%}
                        <span class="nuumi-pawpoint-hero__pack-subtitle">{{ block.settings.subtitle }}</span>
                      {%- endif -%}
                      {%- if block.settings.note != blank -%}
                        <span class="nuumi-pawpoint-hero__pack-note">{{ block.settings.note }}</span>
                      {%- endif -%}
                      <span class="nuumi-pawpoint-hero__pack-per" data-pack-per></span>
                      <span class="nuumi-pawpoint-hero__pack-save" data-pack-save></span>
                    </label>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}

            <product-form class="product-form" data-section-id="{{ section.id }}">
              <div class="product-form__error-message-wrapper" role="alert" hidden>
                <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                <span class="product-form__error-message"></span>
              </div>

              {%- form 'product', product, id: form_id, class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                <input type="hidden" name="id" value="{{ current_variant.id }}" class="product-variant-id">
                <input type="hidden" name="quantity" value="{{ default_quantity }}" data-quantity-input>
                <input type="hidden" name="properties[Purchase option]" value="{% if subscribe_enabled %}{{ section.settings.subscribe_label }}{% else %}{{ section.settings.one_time_label }}{% endif %}" data-purchase-option>
                <input type="hidden" name="properties[Bundle]" value="{{ default_bundle_title }}" data-bundle-label>

                <div class="nuumi-pawpoint-hero__cta-group">
                  <button
                    id="ProductSubmitButton-{{ section.id }}"
                    type="submit"
                    name="add"
                    class="nuumi-button--gold nuumi-pawpoint-hero__cta product-form__submit"
                    {% if current_variant.available == false %}disabled{% endif %}
                  >
                    <span data-atc-label>
                      {%- if current_variant.available == false -%}
                        {{ 'products.product.sold_out' | t }}
                      {%- else -%}
                        {{ section.settings.cta_label }}
                      {%- endif -%}
                    </span>
                    {%- render 'loading-spinner' -%}
                  </button>

                  {%- if section.settings.one_time_cta_note != blank -%}
                    <p class="nuumi-pawpoint-hero__cta-note" data-cta-note>{{ section.settings.one_time_cta_note }}</p>
                  {%- endif -%}
                </div>
              {%- endform -%}
            </product-form>

            <div class="nuumi-pawpoint-hero__micro-trust">
              {%- if section.settings.shipping_note != blank -%}
                <span>{{ section.settings.shipping_note }}</span>
              {%- endif -%}
              {%- if section.settings.guarantee_note != blank -%}
                <span>{{ section.settings.guarantee_note }}</span>
              {%- endif -%}
              {%- if section.settings.payment_note != blank -%}
                <span>{{ section.settings.payment_note }}</span>
              {%- endif -%}
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</product-info>

{%- if section.settings.enable_sticky_cta -%}
  <div class="nuumi-sticky-cta nuumi-sticky-cta--pawpoint" data-sticky-cta>
    <div class="nuumi-sticky-cta__inner page-width">
      <div class="nuumi-sticky-cta__info">
        <span class="nuumi-sticky-cta__title">{{ product.title }}</span>
        <span class="nuumi-sticky-cta__price" data-sticky-price>{{ one_time_total_price | money }}</span>
      </div>
      <button type="button" class="nuumi-button--gold nuumi-sticky-cta__button" data-sticky-button>
        {{ section.settings.sticky_button_label }}
      </button>
    </div>
  </div>
{%- endif -%}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var sectionRoot = document.getElementById('MainProduct-{{ section.id }}');
    if (!sectionRoot) return;

    var basePrice = {{ base_price | json }};
    var baseCompareAtPrice = {{ base_compare_at_price | default: 0 | json }};
    var sectionSettings = {
      subscribeDiscountPercent: {{ section.settings.subscribe_discount_percent | default: 0 | json }},
      oneTimeLabel: {{ section.settings.one_time_label | json }},
      oneTimeModeText: {{ section.settings.one_time_mode_text | json }},
      oneTimeNote: {{ section.settings.one_time_note | json }},
      oneTimeBadge: {{ section.settings.one_time_badge | json }},
      ctaLabel: {{ section.settings.cta_label | json }},
      stickyLabel: {{ section.settings.sticky_button_label | json }},
      oneTimeCtaNote: {{ section.settings.one_time_cta_note | json }},
      subscribeLabel: {{ section.settings.subscribe_label | json }},
      subscribeBadge: {{ section.settings.subscribe_badge | json }},
      subscribeNote: {{ section.settings.subscribe_note | json }}
    };

    var priceEl = sectionRoot.querySelector('[data-total-price]');
    var stickyPriceEl = document.querySelector('.nuumi-sticky-cta--pawpoint [data-sticky-price]');
    var quantityInput = sectionRoot.querySelector('[data-quantity-input]');
    var bundleInput = sectionRoot.querySelector('[data-bundle-label]');
    var purchaseOptionInput = sectionRoot.querySelector('[data-purchase-option]');
    var atcLabel = sectionRoot.querySelector('[data-atc-label]');
    var ctaNote = sectionRoot.querySelector('[data-cta-note]');
    var priceNote = sectionRoot.querySelector('[data-price-note]');
    var comparePriceEl = sectionRoot.querySelector('[data-compare-price]');
    var priceChip = sectionRoot.querySelector('[data-price-chip]');
    var packInputs = sectionRoot.querySelectorAll('input[name="pawpoint_pack_{{ section.id }}"]');
    var modeInputs = sectionRoot.querySelectorAll('input[name="pawpoint_mode_{{ section.id }}"]');
    var stickyCta = document.querySelector('.nuumi-sticky-cta--pawpoint[data-sticky-cta]');
    var stickyButton = stickyCta ? stickyCta.querySelector('[data-sticky-button]') : null;
    var submitButton = document.getElementById('ProductSubmitButton-{{ section.id }}');
    var buyCard = sectionRoot.querySelector('.nuumi-pawpoint-hero__purchase-card');

    function formatMoney(cents) {
      if (!window.Shopify || typeof window.Shopify.formatMoney !== 'function') {
        return '$' + (cents / 100).toFixed(2);
      }
      return window.Shopify.formatMoney(cents);
    }

    function getSelectedPack() {
      var checked = sectionRoot.querySelector('input[name="pawpoint_pack_{{ section.id }}"]:checked');
      return checked || packInputs[0];
    }

    function getSelectedMode() {
      var checkedMode = sectionRoot.querySelector('input[name="pawpoint_mode_{{ section.id }}"]:checked');
      return checkedMode ? checkedMode.value : 'one_time';
    }

    function updateModeCards(selectedMode) {
      sectionRoot.querySelectorAll('[data-mode-card]').forEach(function(card) {
        card.classList.remove('is-selected');
      });
      var active = sectionRoot.querySelector('[data-mode-card="' + selectedMode + '"]');
      if (active) active.classList.add('is-selected');
    }

    function updateDisplay() {
      var selectedPack = getSelectedPack();
      var selectedMode = getSelectedMode();
      var quantity = selectedPack ? parseInt(selectedPack.dataset.qty || '1', 10) : 1;
      var packDiscount = selectedPack ? parseFloat(selectedPack.dataset.discount || '0') / 100 : 0;
      var subscribeDiscount = selectedMode === 'subscribe' ? (parseFloat(sectionSettings.subscribeDiscountPercent || 0) / 100) : 0;
      var baseTotal = Math.round(basePrice * quantity);
      var compareBaseTotal = Math.round(baseCompareAtPrice * quantity);
      var afterPackDiscount = Math.round(baseTotal * (1 - packDiscount));
      var total = Math.round(afterPackDiscount * (1 - subscribeDiscount));
      var compareTotal = Math.round(compareBaseTotal * (1 - packDiscount));

      updateModeCards(selectedMode);

      if (selectedPack) {
        sectionRoot.querySelectorAll('.nuumi-pawpoint-hero__pack').forEach(function(card) {
          card.classList.remove('is-selected');
        });
        var selectedCard = selectedPack.closest('.nuumi-pawpoint-hero__pack');
        if (selectedCard) selectedCard.classList.add('is-selected');
      }

      if (quantityInput) quantityInput.value = quantity;
      if (purchaseOptionInput) purchaseOptionInput.value = selectedMode === 'subscribe' ? sectionSettings.subscribeLabel : sectionSettings.oneTimeLabel;
      if (bundleInput && selectedPack) bundleInput.value = selectedPack.dataset.title || '';
      if (priceEl) priceEl.textContent = formatMoney(total);
      if (stickyPriceEl) stickyPriceEl.textContent = formatMoney(total);
      if (atcLabel) atcLabel.textContent = sectionSettings.ctaLabel;
      if (priceNote) priceNote.textContent = selectedMode === 'subscribe' ? sectionSettings.subscribeNote : sectionSettings.oneTimeNote;
      if (comparePriceEl) {
        var shouldShowCompare = baseCompareAtPrice > basePrice && compareTotal > total;
        comparePriceEl.textContent = shouldShowCompare ? formatMoney(compareTotal) : '';
        comparePriceEl.style.display = shouldShowCompare ? 'block' : 'none';
      }
      if (priceChip) {
        priceChip.textContent = selectedMode === 'subscribe' ? sectionSettings.subscribeBadge : sectionSettings.oneTimeBadge;
        priceChip.style.display = priceChip.textContent ? 'inline-flex' : 'inline-flex';
      }
      if (ctaNote) ctaNote.textContent = sectionSettings.oneTimeCtaNote;
      if (stickyButton) stickyButton.textContent = sectionSettings.stickyLabel;

      packInputs.forEach(function(input) {
        var card = input.closest('.nuumi-pawpoint-hero__pack');
        if (!card) return;

        var packQty = parseInt(input.dataset.qty || '1', 10);
        var packLevelDiscount = parseFloat(input.dataset.discount || '0') / 100;
        var packBaseTotal = Math.round(basePrice * packQty);
        var packOneTime = Math.round(packBaseTotal * (1 - packLevelDiscount));
        var packFinal = Math.round(packOneTime * (1 - subscribeDiscount));
        var perPack = Math.round(packFinal / Math.max(packQty, 1));
        var savings = Math.max(packBaseTotal - packFinal, 0);

        var perNode = card.querySelector('[data-pack-per]');
        var saveNode = card.querySelector('[data-pack-save]');

        if (perNode) perNode.textContent = formatMoney(perPack) + '/pack';
        if (saveNode) {
          saveNode.textContent = savings > 0 ? 'Save ' + formatMoney(savings) : '';
          saveNode.style.display = savings > 0 ? 'inline-flex' : 'none';
        }
      });
    }

    packInputs.forEach(function(input) { input.addEventListener('change', updateDisplay); });
    modeInputs.forEach(function(input) { input.addEventListener('change', updateDisplay); });

    if (stickyButton && submitButton) {
      stickyButton.addEventListener('click', function() {
        submitButton.click();
      });
    }

    if (stickyCta && buyCard) {
      var syncStickyCta = function() {
        var rect = buyCard.getBoundingClientRect();
        var shouldShow = rect.bottom <= 0;
        stickyCta.classList.toggle('nuumi-sticky-cta--visible', shouldShow);
      };

      var observer = new IntersectionObserver(function() {
        syncStickyCta();
      }, { threshold: [0, 1] });

      observer.observe(buyCard);
      window.addEventListener('scroll', syncStickyCta, { passive: true });
      window.addEventListener('resize', syncStickyCta);
      syncStickyCta();
    }

    if (typeof subscribe === 'function' && typeof PUB_SUB_EVENTS !== 'undefined' && PUB_SUB_EVENTS.variantChange) {
      subscribe(PUB_SUB_EVENTS.variantChange, function(event) {
        var payload = event && event.data ? event.data : null;
        if (!payload || payload.sectionId !== '{{ section.id }}' || !payload.variant) return;

        basePrice = payload.variant.price || basePrice;
        baseCompareAtPrice = payload.variant.compare_at_price || 0;
        updateDisplay();
      });
    }

    updateDisplay();
  });
</script>

{% schema %}
{
  "name": "Nuumi PawPoint Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "checkbox", "id": "enable_sticky_cta", "label": "Enable mobile sticky CTA", "default": true },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Did You Know Up To 70% Of Dogs Develop Ear Problems?" },
    { "type": "text", "id": "badge_primary", "label": "Primary badge", "default": "Veterinary Developed" },
    { "type": "text", "id": "badge_secondary", "label": "Secondary badge", "default": "pH-Balanced Formula" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Stop the 3AM Ear Scratching and Head Shaking for Good." },
    { "type": "textarea", "id": "subtitle", "label": "Subtitle", "default": "The finger-fit wipe that reaches the hidden folds of your dog's ear where traditional Q-tips and liquid drops can't go." },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>PawPoint gives you finger-control precision so you can wipe hidden folds, lift away visible gunk, and clean the areas bulky tools often miss.</p>" },
    { "type": "range", "id": "rating_value", "label": "Rating", "min": 0, "max": 5, "step": 0.1, "default": 4.8 },
    { "type": "text", "id": "review_count", "label": "Review count", "default": "3,200+" },
    { "type": "text", "id": "rating_caption", "label": "Rating caption", "default": "Cleaner ears" },
    { "type": "text", "id": "price_label", "label": "Price label", "default": "Choose your supply" },
    { "type": "text", "id": "purchase_mode_heading", "label": "Purchase mode heading", "default": "Choose purchase option" },
    { "type": "text", "id": "one_time_label", "label": "One-time label", "default": "One-Time Purchase" },
    { "type": "text", "id": "one_time_mode_text", "label": "One-time mode text", "default": "Pay once, no subscription" },
    { "type": "text", "id": "one_time_note", "label": "Price note", "default": "One-time purchase. No hidden fees." },
    { "type": "text", "id": "one_time_badge", "label": "Price badge", "default": "One-Time Purchase" },
    { "type": "checkbox", "id": "enable_subscribe_mode", "label": "Enable subscribe option", "default": true },
    { "type": "range", "id": "subscribe_discount_percent", "label": "Subscribe discount (%)", "min": 0, "max": 40, "step": 1, "default": 15 },
    { "type": "text", "id": "subscribe_label", "label": "Subscribe label", "default": "Subscribe & Save" },
    { "type": "text", "id": "subscribe_badge", "label": "Subscribe badge", "default": "Save 15%" },
    { "type": "text", "id": "subscribe_note", "label": "Subscribe note", "default": "Recurring ear-care support. Skip or cancel anytime." },
    { "type": "text", "id": "pack_heading", "label": "Pack heading", "default": "Choose your bundle" },
    { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Add PawPoint to cart" },
    { "type": "text", "id": "sticky_button_label", "label": "Sticky CTA label", "default": "Add to cart" },
    { "type": "text", "id": "one_time_cta_note", "label": "CTA note", "default": "Built for homes that need a cleaner, easier-to-control ear-care routine." },
    { "type": "text", "id": "shipping_note", "label": "Shipping note", "default": "Fast US shipping" },
    { "type": "text", "id": "guarantee_note", "label": "Guarantee note", "default": "30-day money-back guarantee" },
    { "type": "text", "id": "payment_note", "label": "Payment note", "default": "Secure checkout with major payment methods" },
    { "type": "header", "content": "Left Guarantee Block" },
    { "type": "image_picker", "id": "left_guarantee_image", "label": "Guarantee badge image" },
    { "type": "text", "id": "left_guarantee_title", "label": "Guarantee title", "default": "Try it worry-free for 30 days" },
