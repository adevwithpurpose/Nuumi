{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-home-hero">
  {%- if section.settings.image != blank -%}
    <div class="nuumi-home-hero__image-container">
      {{ section.settings.image | image_url: width: 2000 | image_tag:
        loading: 'eager',
        class: 'nuumi-home-hero__image',
        widths: '750, 1100, 1500, 1780, 2000',
        alt: section.settings.image.alt | escape
      }}
    </div>
  {%- endif -%}

  <div class="nuumi-home-hero__content">
    <div class="nuumi-home-hero__panel">
      {%- if section.settings.title != blank -%}
        <h1 class="nuumi-home-hero__title">{{ section.settings.title | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="nuumi-home-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="nuumi-home-hero__bullets">
          {%- for block in section.blocks -%}
            {%- if block.type == 'bullet' -%}
              <li class="nuumi-home-hero__bullet" {{ block.shopify_attributes }}>
                {% render 'nuumi-icon-media', icon_source: block.settings.icon_source, icon: block.settings.icon, custom_svg: block.settings.custom_svg, image: block.settings.custom_image, wrapper_class: 'nuumi-icon', icon_class: 'nuumi-icon', image_width: 48, image_sizes: '24px', image_widths: '24, 36, 48', alt: block.settings.text %}
                <span>{{ block.settings.text | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <div class="nuumi-home-hero__cta">
          <a href="{{ section.settings.button_link }}" class="nuumi-button--gold">
            {{ section.settings.button_label | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Home Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "A simpler way to shop for the pet problems families deal with every day."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Nuumipet organizes targeted essentials around gut health, calming, bark control, ear hygiene, and broader daily support so you can understand what each product does and what to reach for first."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the Essentials"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet",
      "settings": [
        {
          "type": "select",
          "id": "icon_source",
          "label": "Icon Source",
          "options": [
            { "value": "icon", "label": "Theme Icon" },
            { "value": "svg", "label": "Custom SVG" },
            { "value": "image", "label": "Image" }
          ],
          "default": "icon"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check_mark", "label": "Check Mark" },
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "paw", "label": "Paw" }
          ],
          "default": "check_mark"
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG Markup"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Bullet text",
          "default": "Start with the one issue you want to solve first"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Home Hero",
      "blocks": [
        {
          "type": "bullet"
        },
        {
          "type": "bullet"
        },
        {
          "type": "bullet"
        },
        {
          "type": "bullet"
        }
      ]
    }
  ]
}
{% endschema %}
