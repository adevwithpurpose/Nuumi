{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-home-hero">
  {%- if section.settings.image != blank -%}
    <div class="nuumi-home-hero__image-container">
      {{ section.settings.image | image_url: width: 2000 | image_tag:
        loading: 'eager',
        class: 'nuumi-home-hero__image',
        widths: '750, 1100, 1500, 1780, 2000',
        alt: section.settings.image.alt | escape
      }}
    </div>
  {%- endif -%}

  <div class="nuumi-home-hero__content">
    <div class="nuumi-home-hero__panel">
      {%- if section.settings.title != blank -%}
        <h1 class="nuumi-home-hero__title">{{ section.settings.title | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.subtitle != blank -%}
        <p class="nuumi-home-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="nuumi-home-hero__bullets">
          {%- for block in section.blocks -%}
            {%- if block.type == 'bullet' -%}
              <li class="nuumi-home-hero__bullet" {{ block.shopify_attributes }}>
                {% render 'nuumi-icons', icon: 'check_mark', class: 'nuumi-icon' %}
                <span>{{ block.settings.text | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <div class="nuumi-home-hero__cta">
          <a href="{{ section.settings.button_link }}" class="nuumi-button--gold">
            {{ section.settings.button_label | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Home Hero",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Real support for the pet problems families deal with every day."
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Nuumipet brings together targeted essentials for gut health, calming, bark control, ear hygiene, and multi-need support in one cleaner, easier-to-trust routine."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the Essentials"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    }
  ],
  "blocks": [
    {
      "type": "bullet",
      "name": "Bullet",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Bullet text",
          "default": "Gut, calm, bark, and hygiene support"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Home Hero",
      "blocks": [
        {
          "type": "bullet"
        },
        {
          "type": "bullet"
        },
        {
          "type": "bullet"
        }
      ]
    }
  ]
}
{% endschema %}
