{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="nuumi-hero nuumi-section section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="nuumi-hero__grid page-width">
    <div class="nuumi-hero__content nuumi-home-reveal">
      {%- if section.settings.rating_text != blank -%}
        <div class="nuumi-rating nuumi-hero__rating">
          <div class="nuumi-rating__stars">
            <span class="nuumi-rating__star">{% render 'nuumi-icons', icon: 'star' %}</span>
            <span class="nuumi-rating__star">{% render 'nuumi-icons', icon: 'star' %}</span>
            <span class="nuumi-rating__star">{% render 'nuumi-icons', icon: 'star' %}</span>
            <span class="nuumi-rating__star">{% render 'nuumi-icons', icon: 'star' %}</span>
            <span class="nuumi-rating__star">{% render 'nuumi-icons', icon: 'star' %}</span>
          </div>
          <p class="nuumi-rating__label">{{ section.settings.rating_text }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-kicker">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="nuumi-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}
      
      {%- if section.settings.subheading != blank -%}
        <p class="nuumi-hero__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}

      <ul class="nuumi-hero__bullet-points">
        {%- if section.settings.bullet_1 != blank -%}
          <li class="nuumi-hero__bullet">
            <span class="nuumi-hero__bullet-icon">{% render 'nuumi-icons', icon: 'check_mark' %}</span>
            <span class="nuumi-hero__bullet-text">{{ section.settings.bullet_1 }}</span>
          </li>
        {%- endif -%}
        {%- if section.settings.bullet_2 != blank -%}
          <li class="nuumi-hero__bullet">
            <span class="nuumi-hero__bullet-icon">{% render 'nuumi-icons', icon: 'check_mark' %}</span>
            <span class="nuumi-hero__bullet-text">{{ section.settings.bullet_2 }}</span>
          </li>
        {%- endif -%}
        {%- if section.settings.bullet_3 != blank -%}
          <li class="nuumi-hero__bullet">
            <span class="nuumi-hero__bullet-icon">{% render 'nuumi-icons', icon: 'check_mark' %}</span>
            <span class="nuumi-hero__bullet-text">{{ section.settings.bullet_3 }}</span>
          </li>
        {%- endif -%}
      </ul>

      <div class="nuumi-home-button-row">
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="nuumi-home-button">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      </div>

      {% render 'nuumi-badge-list', blocks: section.blocks, class: 'nuumi-hero__badges' %}
    </div>

    <div class="nuumi-hero__media nuumi-home-reveal">
      <div class="nuumi-hero__image-wrap">
      {%- if section.settings.image != blank -%}
        <img
          srcset="
            {%- if section.settings.image.width >= 375 -%}{{ section.settings.image | image_url: width: 375 }} 375w,{%- endif -%}
            {%- if section.settings.image.width >= 750 -%}{{ section.settings.image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if section.settings.image.width >= 1100 -%}{{ section.settings.image | image_url: width: 1100 }} 1100w,{%- endif -%}
            {%- if section.settings.image.width >= 1500 -%}{{ section.settings.image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ section.settings.image | image_url }} {{ section.settings.image.width }}w
          "
          src="{{ section.settings.image | image_url: width: 1500 }}"
          sizes="(min-width: 900px) 50vw, 100vw"
          alt="{{ section.settings.image.alt | escape }}"
          loading="eager"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          class="nuumi-hero__image"
        >
      {%- else -%}
        {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg nuumi-hero__image' }}
      {%- endif -%}

      {%- if section.settings.callout_title != blank or section.settings.callout_text != blank -%}
        <div class="nuumi-hero__callout">
          <span class="nuumi-proof-card__icon">{% render 'nuumi-icons', icon: 'shield' %}</span>
          <div>
            {%- if section.settings.callout_label != blank -%}
              <p class="nuumi-hero__callout-label">{{ section.settings.callout_label }}</p>
            {%- endif -%}
            {%- if section.settings.callout_title != blank -%}
              <p class="nuumi-hero__callout-title">{{ section.settings.callout_title }}</p>
            {%- endif -%}
            {%- if section.settings.callout_text != blank -%}
              <p class="nuumi-hero__callout-text">{{ section.settings.callout_text }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <div class="nuumi-hero__floating-note">
        <p class="nuumi-hero__floating-label">Designed for review</p>
        <p class="nuumi-hero__floating-title">A calmer storefront that sells through clarity, not clutter</p>
      </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
