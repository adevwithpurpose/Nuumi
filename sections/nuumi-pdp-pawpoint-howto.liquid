{{ 'nuumi-pdp.css' | asset_url | stylesheet_tag }}

<div class="nuumi-pawpoint-howto section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-pawpoint-howto__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="nuumi-pawpoint-howto__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="nuumi-pawpoint-howto__title">{{ section.settings.title }}</h2>
      {%- if section.settings.text != blank -%}
        <p class="nuumi-pawpoint-howto__text">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <div class="nuumi-pawpoint-howto__steps">
      {%- for block in section.blocks -%}
        <article class="nuumi-pawpoint-howto__step" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank -%}
            <div class="nuumi-pawpoint-howto__media-wrap">
              {{ block.settings.image | image_url: width: 600 | image_tag:
                loading: 'lazy',
                class: 'nuumi-pawpoint-howto__image',
                widths: '300, 450, 600'
              }}
            </div>
          {%- elsif block.settings.video != blank or block.settings.video_url != blank -%}
            <div class="nuumi-pawpoint-howto__media-wrap nuumi-pawpoint-howto__media-wrap--video">
              {%- if block.settings.video != blank -%}
                {{ block.settings.video | video_tag: controls: true, autoplay: false, loop: false, muted: false, class: 'nuumi-pawpoint-howto__video', preload: 'metadata' }}
              {%- elsif block.settings.video_url != blank -%}
                {%- if block.settings.video_url.type == 'youtube' -%}
                  {%- assign video_id = block.settings.video_url.id -%}
                  <iframe
                    class="nuumi-pawpoint-howto__video"
                    src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&rel=0&modestbranding=1"
                    allow="autoplay; encrypted-media; picture-in-picture"
                    allowfullscreen
                    title="{{ block.settings.title }}"
                    loading="lazy"
                  ></iframe>
                {%- else -%}
                  {%- assign video_id = block.settings.video_url.id -%}
                  <iframe
                    class="nuumi-pawpoint-howto__video"
                    src="https://player.vimeo.com/video/{{ video_id }}?title=0&byline=0&portrait=0"
                    allow="autoplay; encrypted-media; picture-in-picture"
                    allowfullscreen
                    title="{{ block.settings.title }}"
                    loading="lazy"
                  ></iframe>
                {%- endif -%}
              {%- endif -%}
            </div>
          {%- else -%}
            <div class="nuumi-pawpoint-howto__icon-wrap">
              <span class="nuumi-pawpoint-howto__step-number">{{ forloop.index }}</span>
              {%- if block.settings.icon != blank -%}
                <span class="nuumi-pawpoint-howto__icon">{% render 'nuumi-icons', icon: block.settings.icon %}</span>
              {%- endif -%}
            </div>
          {%- endif -%}

          <div class="nuumi-pawpoint-howto__step-body">
            <h3 class="nuumi-pawpoint-howto__step-title">{{ block.settings.title }}</h3>
            {%- if block.settings.text != blank -%}
              <p class="nuumi-pawpoint-howto__step-text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Nuumi PawPoint How-To",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#F9FAFB" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How to use" },
    { "type": "text", "id": "title", "label": "Heading", "default": "Three Steps to Healthier Ears" },
    { "type": "text", "id": "text", "label": "Subtext", "default": "A quick daily routine that takes less than a minute." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image (optional, replaces icon)" },
        { "type": "video", "id": "video", "label": "Shopify Video (optional, replaces icon)" },
        { "type": "video_url", "id": "video_url", "accept": ["youtube", "vimeo"], "label": "External Video URL (optional)" },
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "paw", "label": "Paw" }, { "value": "heart", "label": "Heart" }, { "value": "shield", "label": "Shield" }, { "value": "check_mark", "label": "Check" }, { "value": "star", "label": "Star" }, { "value": "leaf", "label": "Leaf" }], "default": "paw" },
        { "type": "text", "id": "title", "label": "Step Title", "default": "Wrap your finger" },
        { "type": "text", "id": "text", "label": "Step Description", "default": "Slip the PawPoint wipe over your index finger for full control." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi PawPoint How-To",
      "blocks": [
        { "type": "step", "settings": { "icon": "paw", "title": "Wrap your finger", "text": "Slip the PawPoint wipe over your index finger for full control." } },
        { "type": "step", "settings": { "icon": "check_mark", "title": "Wipe the hidden folds", "text": "Gently reach into the ear fold and wipe away gunk, odor, and buildup." } },
        { "type": "step", "settings": { "icon": "heart", "title": "Done in seconds", "text": "Dispose and move on. No mess, no dripping, no rinse needed." } }
      ]
    }
  ]
}
{% endschema %}
