{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nuumi-section nuumi-product-page nuumi-product-story section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-product-story__grid">
      <div class="nuumi-product-story__image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag: widths: '720, 960, 1200, 1400', sizes: '(min-width: 990px) 50vw, 100vw', loading: 'lazy' }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="nuumi-product-story__content">
        {%- if section.settings.eyebrow != blank -%}<p class="nuumi-kicker">{{ section.settings.eyebrow }}</p>{%- endif -%}
        <h2 class="nuumi-section-heading">{{ section.settings.heading }}</h2>
        <div class="nuumi-product-story__body rte">{{ section.settings.body }}</div>
      </div>
    </div>
    <div class="nuumi-product-story__cards">
      {%- for block in section.blocks -%}
        <article class="nuumi-product-story-card" {{ block.shopify_attributes }}>
          <span class="nuumi-product-story-card__eyebrow">{{ block.settings.eyebrow }}</span>
          <h3 class="nuumi-product-story-card__title">{{ block.settings.title }}</h3>
          <div class="nuumi-product-story-card__text rte">{{ block.settings.text }}</div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Product Story",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Problem and promise" },
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Explain the problem, the product role, and the calmer routine it supports" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Use this section to connect the customer problem to the product without over-claiming. Keep the tone premium, practical, and clear.</p>" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Top padding", "default": 24 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 140, "step": 4, "unit": "px", "label": "Bottom padding", "default": 48 }
  ],
  "blocks": [
    {
      "type": "story_card",
      "name": "Story card",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Context" },
        { "type": "text", "id": "title", "label": "Title", "default": "What the customer feels first" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Use a few lines to frame the problem or desired outcome with empathy and clarity.</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "Nuumi Product Story", "blocks": [{ "type": "story_card" }, { "type": "story_card" }] }
  ]
}
{% endschema %}
