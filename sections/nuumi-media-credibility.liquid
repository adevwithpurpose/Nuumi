{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-media-credibility section-{{ section.id }}-padding">
  <div class="page-width">
    {%- if section.blocks.size > 0 -%}
      <div class="nuumi-media-credibility__logos-wrap">
        {%- if section.settings.logos_eyebrow != blank -%}
          <p class="nuumi-media-credibility__logos-eyebrow">{{ section.settings.logos_eyebrow | escape }}</p>
        {%- endif -%}

        <div class="nuumi-media-credibility__logos" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'logo' -%}
              <div class="nuumi-media-credibility__logo" role="listitem" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {{ block.settings.image | image_url: width: 320 | image_tag:
                    class: 'nuumi-media-credibility__logo-image',
                    loading: 'lazy',
                    widths: '120, 180, 240, 320',
                    alt: block.settings.label | escape
                  }}
                {%- else -%}
                  {{ block.settings.label | escape }}
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="nuumi-media-credibility__panel">
      <div class="nuumi-media-credibility__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="nuumi-media-credibility__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="nuumi-media-credibility__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        <div class="nuumi-media-credibility__stats" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'stat' -%}
              <div class="nuumi-media-credibility__stat" role="listitem" {{ block.shopify_attributes }}>
                {%- if block.settings.value != blank -%}
                  <p class="nuumi-media-credibility__stat-value">{{ block.settings.value | escape }}</p>
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <p class="nuumi-media-credibility__stat-label">{{ block.settings.label | escape }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      <div class="nuumi-media-credibility__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag:
            class: 'nuumi-media-credibility__image',
            loading: 'lazy',
            widths: '500, 700, 900, 1200, 1400',
            alt: section.settings.heading | escape
          }}
        {%- else -%}
          <div class="nuumi-media-credibility__image-placeholder">
            {% render 'nuumi-icons', icon: 'heart', class: 'nuumi-media-credibility__placeholder-icon' %}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Media Credibility",
  "settings": [
    {
      "type": "text",
      "id": "logos_eyebrow",
      "label": "Logos eyebrow",
      "default": "As seen on sponsored content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your pet health optimization partner™"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Just the science. No hyperbole. No unsupported health claims. We deliver exceptional products and honest advice to support your pet's health.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "CBS"
        }
      ]
    },
    {
      "type": "stat",
      "name": "Stat",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "100k+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Five-Star Reviews Globally"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Media Credibility",
      "blocks": [
        { "type": "logo", "settings": { "label": "CBS" } },
        { "type": "logo", "settings": { "label": "ABC" } },
        { "type": "logo", "settings": { "label": "NBC" } },
        { "type": "logo", "settings": { "label": "BuzzFeed" } },
        { "type": "logo", "settings": { "label": "Forbes" } },
        { "type": "stat", "settings": { "value": "100k+", "label": "Five-Star Reviews Globally" } },
        { "type": "stat", "settings": { "value": "3", "label": "Successful Clinical Studies" } },
        { "type": "stat", "settings": { "value": "12", "label": "Proprietary Formulas" } },
        { "type": "stat", "settings": { "value": "1", "label": "Patent-Pending Formula" } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
