{{ 'nuumi-pdp.css' | asset_url | stylesheet_tag }}

<div class="nuumi-pdp-expert section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-expert__grid">
      <div class="nuumi-expert__media-shell">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 900 | image_tag:
            loading: 'lazy',
            class: 'nuumi-expert__image',
            widths: '320, 480, 640, 900'
          }}
        {%- endif -%}
      </div>
      <div class="nuumi-expert__content">
        {%- if section.settings.badge_text != blank -%}
          <p class="nuumi-expert__badge">{{ section.settings.badge_text }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="nuumi-expert__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        <div class="nuumi-expert__quote">{{ section.settings.quote }}</div>
        <div class="nuumi-expert__author">
          <p class="nuumi-expert__name">{{ section.settings.name }}</p>
          <p class="nuumi-expert__credentials">{{ section.settings.credentials }}</p>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Leash Walk Authority",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#FFFFFF" },
    { "type": "image_picker", "id": "image", "label": "Trainer image" },
    { "type": "text", "id": "badge_text", "label": "Badge text", "default": "Instructor authority" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Meet Cinzia, the trainer behind the course." },
    { "type": "richtext", "id": "quote", "label": "Bio text", "default": "<p>With 13+ years of experience as a dog trainer, Cinzia teaches the small but powerful strategies that help your dog recognize you as the guide on every walk.</p>" },
    { "type": "text", "id": "name", "label": "Name", "default": "Cinzia" },
    { "type": "text", "id": "credentials", "label": "Credentials", "default": "13+ years of dog-training experience" }
  ],
  "presets": [
    { "name": "Leash Walk Authority" }
  ]
}
{% endschema %}
