{{ 'nuumi-pdp.css' | asset_url | stylesheet_tag }}

<div class="nuumi-faq section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-faq__header">
      {%- if section.settings.title != blank -%}
        <h2 class="nuumi-faq__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>
    
    {%- if section.blocks.size > 0 -%}
      <div class="nuumi-faq__accordion">
        {%- for block in section.blocks -%}
          <details class="nuumi-faq__item" {{ block.shopify_attributes }}>
            <summary class="nuumi-faq__summary">
              <span class="nuumi-faq__question">{{ block.settings.question }}</span>
              <span class="nuumi-faq__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </span>
            </summary>
            <div class="nuumi-faq__answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Nuumi FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9FAFB"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long until I see results?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Most pet parents notice a difference in their dog's mobility and energy levels within 3-4 weeks of consistent daily use.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How is PawPoint different from regular ear wipes?",
            "answer": "<p>Regular flat wipes sit on the surface — they cannot reach the hidden vertical folds inside the ear where gunk and odor actually build up. PawPoint wraps around your finger, giving you precision control to clean those folds without pushing debris further in.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Will my dog stay still for this?",
            "answer": "<p>Most dogs tolerate PawPoint well because it is gentle and takes under a minute. Start by letting your dog sniff the wipe, then work quickly and calmly. If your dog is squirmy, try doing it after a walk or meal when they are naturally more relaxed.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How often should I use PawPoint?",
            "answer": "<p>For most dogs, 2–3 times a week is enough for maintenance. If your dog is prone to ear buildup, odor, or has a history of ear issues, daily use during the first two weeks can help establish a cleaner baseline routine.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Is PawPoint safe for puppies or senior dogs?",
            "answer": "<p>Yes. PawPoint uses a pH-balanced, gentle formula suitable for dogs of all ages. For puppies, always handle the ear gently and avoid going too deep. Senior dogs with stiff joints may benefit from having someone help hold them still during application.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "My dog shakes their head after cleaning — is that normal?",
            "answer": "<p>Yes, it is completely normal. Most dogs shake their head after you touch their ears — it is a natural reflex. Just make sure you have wiped the outer folds and are not inserting the wipe into the ear canal. If your dog shows signs of pain or the shaking persists, check with your vet.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What if my dog has an ear infection?",
            "answer": "<p>PawPoint is designed for routine ear hygiene, not to treat active infections. If your dog has signs of infection — redness, swelling, discharge, or a strong odor — see your vet first. Once the infection is treated, PawPoint can help maintain a cleaner ear environment to prevent recurrence.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What if I am not happy with the results?",
            "answer": "<p>We offer a 30-day money-back guarantee. If PawPoint is not the right fit for your routine or your dog simply does not tolerate it, we will refund your purchase. No complicated forms, no long wait — just reach out and we will take care of it.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}