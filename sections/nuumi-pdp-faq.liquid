{{ 'nuumi-pdp.css' | asset_url | stylesheet_tag }}

<div class="nuumi-faq section-{{ section.id }}-padding" style="background-color: {{ section.settings.bg_color }};">
  <div class="page-width">
    <div class="nuumi-faq__header">
      {%- if section.settings.title != blank -%}
        <h2 class="nuumi-faq__title">{{ section.settings.title }}</h2>
      {%- endif -%}
    </div>
    
    {%- if section.blocks.size > 0 -%}
      <div class="nuumi-faq__accordion">
        {%- for block in section.blocks -%}
          <details class="nuumi-faq__item" {{ block.shopify_attributes }}>
            <summary class="nuumi-faq__summary">
              <span class="nuumi-faq__question">{{ block.settings.question }}</span>
              <span class="nuumi-faq__icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </span>
            </summary>
            <div class="nuumi-faq__answer">
              {{ block.settings.answer }}
            </div>
          </details>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Nuumi FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#F9FAFB"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long until I see results?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Most pet parents notice a difference in their dog's mobility and energy levels within 3-4 weeks of consistent daily use.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi FAQ",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "Will EnerCanis work for my dog?",
            "answer": "<p>EnerCanis addresses the root cause of chronic digestive, skin, and immune issues—damaged intestinal barrier. Our clinical observation showed 83% of dogs with chronic gut-related problems had meaningful improvement when used consistently for 3 months. With our 90-Day Guarantee, you can see results risk-free.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How quickly will I see results?",
            "answer": "<p>Most owners notice firmer stools and reduced gas in 5-7 days. Skin improvements show in weeks 2-4. Energy and vitality increase by weeks 4-6. Complete transformation of chronic patterns typically occurs in 8-12 weeks. Remember: we're healing years of damage, not masking symptoms overnight.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Is EnerCanis safe?",
            "answer": "<p>Absolutely. All ingredients are pharmaceutical-grade and naturally-derived with extensive safety profiles. L-Glutamine and Collagen are nutrients dogs produce naturally. PEA is found in common foods. Probiotic strains are specifically selected for canine gut environments. No harsh chemicals, artificial additives, or known allergens. If your dog takes medications or has health conditions, consult your vet before starting (as with any supplement).</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What if my dog won't eat it?",
            "answer": "<p>The natural beef flavor is highly palatable—most dogs lick their bowls clean. For picky eaters, try mixing with a tablespoon of bone broth or warming the food slightly to enhance aroma. The liquid format ensures they get the full dose even if mixed into wet food or a small amount of high-value treat.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How do I use EnerCanis?",
            "answer": "<p>Simply add the recommended dose directly to your dog's food and mix. Use EnerCanis once daily. The dose depends on the size of your dog, but you will find clear instructions on the product label.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How many bottles should I order?",
            "answer": "<p>It is also depends on the size of your dog, but we do usually recommend the 3-bottle package because intestinal barrier needs consistent support. The 6-bottle package offers best value and ensures supply through complete healing plus maintenance phase. Many customers transition to Subscribe & Save after initial transformation.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What if I accidentally give too much?",
            "answer": "<p>EnerCanis has a wide safety margin. Occasional slight overdosing (like giving 3ml instead of 2ml) is harmless. If significantly overdosed, you might see temporary soft stool as the body adjusts. Simply reduce to normal dose the next day. If concerned, contact your vet.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What happens if I'm not happy with results?",
            "answer": "<p>While many customers are happy with their experience, we know that everybody is different. That’s why we offer a 90-day money-back guarantee. So, if your dog didn't show improvement, we'll refund your purchase as soon as possible, usually within 2-3 business days.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Will you have enough stock for my subscription?",
            "answer": "<p>Yes. Subscribers get priority allocation. We maintain inventory reserves specifically for subscription customers so your dog never runs out during their healing protocol.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Where are ingredients sourced?",
            "answer": "<p>Manufactured in the USA from premium domestic and globally sourced ingredients. All suppliers meet pharmaceutical-grade quality standards and undergo third-party testing for purity and potency.</p>"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "When will I receive my order?",
            "answer": "<p>We ship all orders within 24 hours. Domestic orders typically arrive in 2-3 business days, depending on your location. International shipping may take 7-14 business days. You'll receive a tracking number as soon as your order ships.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
