{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign excluded_tags = section.settings.excluded_tags | split: ',' -%}
{%- assign excluded_types = section.settings.excluded_product_types | split: ',' -%}
{%- assign excluded_handles = section.settings.excluded_product_handles | split: ',' -%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="nuumi-collection-grid__header">
        <h2 class="nuumi-collection-grid__heading">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.description != blank -%}
          <div class="nuumi-collection-grid__description rte">{{ section.settings.description }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- paginate collection.products by section.settings.products_per_page -%}
      <div class="nuumi-collection-grid__products">
        {%- for product in collection.products -%}
          {%- assign exclude = false -%}

          {%- for tag in product.tags -%}
            {%- for excluded_tag in excluded_tags -%}
              {%- assign trimmed_tag = excluded_tag | strip | downcase -%}
              {%- if tag | downcase == trimmed_tag -%}
                {%- assign exclude = true -%}
              {%- endif -%}
            {%- endfor -%}
          {%- endfor -%}

          {%- for excluded_type in excluded_types -%}
            {%- assign trimmed_type = excluded_type | strip | downcase -%}
            {%- if product.type | downcase == trimmed_type -%}
              {%- assign exclude = true -%}
            {%- endif -%}
          {%- endfor -%}

          {%- for excluded_handle in excluded_handles -%}
            {%- assign trimmed_handle = excluded_handle | strip -%}
            {%- if product.handle == trimmed_handle -%}
              {%- assign exclude = true -%}
            {%- endif -%}
          {%- endfor -%}

          {%- unless exclude -%}
            <a href="{{ product.url }}" class="nuumi-collection-grid__card">
              <div class="nuumi-collection-grid__media">
                {%- if product.featured_image != blank -%}
                  {{ product.featured_image | image_url: width: 600 | image_tag:
                    class: 'nuumi-collection-grid__image',
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw',
                    widths: '320, 480, 600',
                    alt: product.featured_image.alt | escape
                  }}
                {%- else -%}
                  <div class="nuumi-collection-grid__placeholder">
                    {% render 'nuumi-icons', icon: 'paw', class: 'nuumi-collection-grid__placeholder-icon' %}
                  </div>
                {%- endif -%}
              </div>
              <div class="nuumi-collection-grid__info">
                <h3 class="nuumi-collection-grid__title">{{ product.title | escape }}</h3>
                <p class="nuumi-collection-grid__price">{{ product.price | money }}</p>
              </div>
            </a>
          {%- endunless -%}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="nuumi-collection-grid__pagination">
          {{ paginate | default_pagination }}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  </div>
</div>

{% schema %}
{
  "name": "Nuumi Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Products"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "textarea",
      "id": "excluded_product_handles",
      "label": "Excluded product handles",
      "info": "Comma-separated product handles to hide (e.g. shipping-protection,nuumipet-vip)",
      "default": "shipping-protection,50-shades-of-fun,nuumipet-vip"
    },
    {
      "type": "textarea",
      "id": "excluded_tags",
      "label": "Excluded tags",
      "info": "Comma-separated tags. Products with any of these tags will be hidden."
    },
    {
      "type": "textarea",
      "id": "excluded_product_types",
      "label": "Excluded product types",
      "info": "Comma-separated product types to hide."
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 4,
      "max": 24,
      "step": 4,
      "default": 12,
      "label": "Products per page"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        { "value": "scheme-1", "label": "t:sections.all.colors.scheme_1.label" },
        { "value": "scheme-2", "label": "t:sections.all.colors.scheme_2.label" },
        { "value": "scheme-3", "label": "t:sections.all.colors.scheme_3.label" },
        { "value": "scheme-4", "label": "t:sections.all.colors.scheme_4.label" },
        { "value": "scheme-5", "label": "t:sections.all.colors.scheme_5.label" }
      ],
      "default": "scheme-1",
      "label": "t:sections.all.colors.label"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Nuumi Collection Grid"
    }
  ]
}
{% endschema %}

<style>
  .nuumi-collection-grid__header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .nuumi-collection-grid__heading {
    font-family: var(--font-heading-family);
    font-size: 2.8rem;
    font-weight: 700;
    color: var(--nuumi-deep-blue);
    margin: 0 0 1rem;
  }

  .nuumi-collection-grid__description {
    font-size: 1.6rem;
    color: rgba(var(--color-foreground), 0.75);
    max-width: 64rem;
    margin: 0 auto;
  }

  .nuumi-collection-grid__products {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
  }

  @media screen and (min-width: 750px) {
    .nuumi-collection-grid__products {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media screen and (min-width: 990px) {
    .nuumi-collection-grid__products {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .nuumi-collection-grid__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(var(--color-background), 1);
    border: 1px solid rgba(var(--color-foreground), 0.08);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .nuumi-collection-grid__card:hover {
    box-shadow: 0 4px 16px rgba(var(--color-shadow), 0.12);
    transform: translateY(-2px);
  }

  .nuumi-collection-grid__media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }

  .nuumi-collection-grid__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .nuumi-collection-grid__card:hover .nuumi-collection-grid__image {
    transform: scale(1.03);
  }

  .nuumi-collection-grid__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    color: rgba(var(--color-foreground), 0.2);
  }

  .nuumi-collection-grid__placeholder-icon {
    width: 4rem;
    height: 4rem;
  }

  .nuumi-collection-grid__info {
    padding: 1.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .nuumi-collection-grid__title {
    font-family: var(--font-heading-family);
    font-size: 1.6rem;
    font-weight: 600;
    color: var(--nuumi-deep-blue);
    margin: 0;
  }

  .nuumi-collection-grid__price {
    font-size: 1.4rem;
    font-weight: 500;
    color: var(--nuumi-gold-dark);
    margin: 0;
  }

  .nuumi-collection-grid__pagination {
    margin-top: 4rem;
    display: flex;
    justify-content: center;
  }
</style>
