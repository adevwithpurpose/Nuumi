{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-benefits-story section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-benefits-story__header center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-benefits-story__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nuumi-benefits-story__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-benefits-story__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-benefits-story__grid">
      {%- for block in section.blocks -%}
        <article class="nuumi-benefits-story__card" {{ block.shopify_attributes }}>
          <div class="nuumi-benefits-story__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 960 | image_tag:
                class: 'nuumi-benefits-story__image',
                loading: 'lazy',
                widths: '320, 480, 720, 960',
                alt: block.settings.title | escape
              }}
            {%- else -%}
              <div class="nuumi-benefits-story__image-placeholder">
                {% render 'nuumi-icons', icon: block.settings.icon, class: 'nuumi-benefits-story__placeholder-icon' %}
              </div>
            {%- endif -%}
          </div>
          <div class="nuumi-benefits-story__content">
            {%- if block.settings.eyebrow != blank -%}
              <p class="nuumi-benefits-story__card-eyebrow">{{ block.settings.eyebrow | escape }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="nuumi-benefits-story__card-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="nuumi-benefits-story__card-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Benefits Story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How the lineup fits together"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Each product solves a different part of the everyday care routine."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>The catalog stays intentionally small so each item can do a specific job well, from gut support and calming to bark control, hygiene, and bundled daily care.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Fallback icon",
          "options": [
            { "value": "paw", "label": "Paw" },
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "leaf", "label": "Leaf" }
          ],
          "default": "science"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Digestive care"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "EnerCanis leads with a clear gut-health job."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "It is built around L-Glutamine, Hydrolyzed Collagen, and prebiotic support to help soothe the gut and support the intestinal barrier."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Nuumi Benefits Story",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit", "settings": { "icon": "shield", "eyebrow": "Behavior support", "title": "ByeBark and CalmiCollar cover two different stress patterns.", "text": "One helps interrupt barking in the moment, while the other supports calmer behavior for dogs that need more environmental reassurance." } },
        { "type": "benefit", "settings": { "icon": "heart", "eyebrow": "Practical care", "title": "PawPoint and the bundle round out the daily routine.", "text": "Ear wipes make preventive hygiene easier, and the Core Wellness Bundle gives multi-need households one simpler place to start." } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
