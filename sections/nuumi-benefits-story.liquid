{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nuumi-section nuumi-benefits-story section-{{ section.id }}-padding">
  <div class="page-width nuumi-home-reveal">
    <div class="nuumi-benefits-story__grid">
      <div class="nuumi-benefits-story__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="nuumi-kicker">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="nuumi-section-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.intro != blank -%}
          <div class="nuumi-benefits-story__intro rte">{{ section.settings.intro }}</div>
        {%- endif -%}
      </div>

      <div class="nuumi-benefits-story__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              widths: '533, 720, 900, 1200',
              loading: 'lazy',
              sizes: '(min-width: 990px) 45vw, 100vw'
          }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <div class="nuumi-benefits-story__cards">
      {%- for block in section.blocks -%}
        <article class="nuumi-benefit-card" {{ block.shopify_attributes }}>
          <span class="nuumi-benefit-card__icon">{% render 'nuumi-icons', icon: block.settings.icon %}</span>
          <span class="nuumi-benefit-card__eyebrow">{{ block.settings.eyebrow }}</span>
          <h3 class="nuumi-benefit-card__title">{{ block.settings.title }}</h3>
          <div class="nuumi-benefit-card__text rte">{{ block.settings.text }}</div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumipet Benefits Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Built for clarity"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Show the science, the routine, and the reason each product earns its place"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>This section works best when it explains the brand promise in simple, high-trust language without overwhelming the shopper.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Supporting image"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit card",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "check", "label": "Check" },
            { "value": "paw", "label": "Paw" }
          ],
          "default": "science"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Why it matters"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Purposeful formulation"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Explain the practical benefit in a few lines. Focus on trust, routine, and customer confidence.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumipet Benefits Story",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" }
      ]
    }
  ]
}
{% endschema %}
