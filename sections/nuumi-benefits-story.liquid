{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-benefits-story section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-benefits-story__header center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-benefits-story__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nuumi-benefits-story__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-benefits-story__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-benefits-story__grid">
      {%- for block in section.blocks -%}
        <article class="nuumi-benefits-story__card" {{ block.shopify_attributes }}>
          <div class="nuumi-benefits-story__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 960 | image_tag:
                class: 'nuumi-benefits-story__image',
                loading: 'lazy',
                widths: '320, 480, 720, 960',
                alt: block.settings.title | escape
              }}
            {%- else -%}
              <div class="nuumi-benefits-story__image-placeholder">
                {% render 'nuumi-icon-media', icon_source: block.settings.icon_source, icon: block.settings.icon, custom_svg: block.settings.custom_svg, image: block.settings.custom_image, wrapper_class: 'nuumi-benefits-story__placeholder-icon-wrap', icon_class: 'nuumi-benefits-story__placeholder-icon', image_width: 96, image_sizes: '48px', image_widths: '48, 72, 96', alt: block.settings.title %}
              </div>
            {%- endif -%}
          </div>
          <div class="nuumi-benefits-story__content">
            {%- if block.settings.eyebrow != blank -%}
              <p class="nuumi-benefits-story__card-eyebrow">{{ block.settings.eyebrow | escape }}</p>
            {%- endif -%}
            {%- if block.settings.title != blank -%}
              <h3 class="nuumi-benefits-story__card-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="nuumi-benefits-story__card-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Benefits Story",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How the system fits together"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The lineup is built so each product does one job clearly, then supports the whole routine together."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>That is the system explanation behind the homepage: a smaller set of essentials, each mapped to a recognizable daily problem, so the store feels easier to understand than a crowded pet-wellness catalog.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "icon_source",
          "label": "Icon Source",
          "options": [
            { "value": "icon", "label": "Theme Icon" },
            { "value": "svg", "label": "Custom SVG" },
            { "value": "image", "label": "Image" }
          ],
          "default": "icon"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Fallback icon",
          "options": [
            { "value": "paw", "label": "Paw" },
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "leaf", "label": "Leaf" }
          ],
          "default": "science"
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG Markup"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Digestive lane"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "EnerCanis covers the gut-support lane with a clearer daily routine."
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "For pets dealing with recurring digestive discomfort, it gives the lineup a dedicated first stop instead of burying gut support inside a generic wellness blend."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Nuumi Benefits Story",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit", "settings": { "icon": "shield", "eyebrow": "Behavior lanes", "title": "ByeBark and CalmiCollar solve different parts of behavior support.", "text": "One is for fast interruption in the moment. The other is for steadier calming support through the day. Together they explain the difference between immediate response and ongoing reassurance." } },
        { "type": "benefit", "settings": { "icon": "heart", "eyebrow": "Routine completion", "title": "PawPoint and The Leash Walk Formula round out the system.", "text": "PawPoint covers practical ear hygiene, while The Leash Walk Formula gives households a broader step-by-step training path when they want support beyond a single product lane." } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
