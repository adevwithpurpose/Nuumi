{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nuumi-section nuumi-faq section-{{ section.id }}-padding">
  <div class="page-width nuumi-home-reveal">
    <div class="nuumi-section-header nuumi-faq__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="nuumi-kicker">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="nuumi-section-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.intro != blank -%}
          <div class="nuumi-faq__intro rte">{{ section.settings.intro }}</div>
        {%- endif -%}
      </div>
    </div>

    <div class="nuumi-faq__list">
      {%- for block in section.blocks -%}
        <details class="nuumi-faq__item" data-nuumi-faq {{ block.shopify_attributes }}>
          <summary class="nuumi-faq__trigger">
            <h3 class="nuumi-faq__question">{{ block.settings.question }}</h3>
            <span class="nuumi-faq__toggle">+</span>
          </summary>
          <div class="nuumi-faq__answer rte">{{ block.settings.answer }}</div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumipet FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Frequently asked questions"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Answer the questions that keep customers from clicking buy"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Use concise answers here to remove friction before the shopper reaches the product page.</p>"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What makes Nuumipet different?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Use a calm, specific answer that focuses on formulation, routine, and customer clarity.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumipet FAQ",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
