{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-faq section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-faq__header center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-faq__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nuumi-faq__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-faq__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-faq__list">
      {%- for block in section.blocks -%}
        <details class="nuumi-faq__item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="nuumi-faq__question">
            <span>{{ block.settings.question | escape }}</span>
            <span class="nuumi-faq__toggle" aria-hidden="true"></span>
          </summary>
          <div class="nuumi-faq__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Before you start"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Helpful answers for a smaller, more focused product range"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Help shoppers understand what each product does, how the lineup works together, and where to find policy details before checkout.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I know which product to start with?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Start with the problem you are trying to solve first: gut health, calming, bark control, ear hygiene, or broader daily support through the bundle.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi FAQ",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item", "settings": { "question": "Can I use more than one product in the routine?", "answer": "<p>Yes, many households shop across more than one care lane. If your pet is already under veterinary care or taking medications, check with your veterinarian first.</p>" } },
        { "type": "faq_item", "settings": { "question": "Where can I review the guarantee details?", "answer": "<p>Nuumipet highlights a 30-day guarantee so you can shop with more confidence. Check the store policy details at checkout or in the footer for the latest terms.</p>" } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
