{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-faq section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-faq__header center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-faq__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nuumi-faq__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-faq__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-faq__list">
      {%- for block in section.blocks -%}
        <details class="nuumi-faq__item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="nuumi-faq__question">
            <span>{{ block.settings.question | escape }}</span>
            <span class="nuumi-faq__toggle" aria-hidden="true"></span>
          </summary>
          <div class="nuumi-faq__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Before you choose"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Helpful answers for a smaller, more focused product range."
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>The goal is to make choosing feel simpler: understand what each product does, why the homepage is curated the way it is, how the lineup works together, and where to find policy details before you check out.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I know which product to start with?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Start with the problem you are trying to solve first. EnerCanis supports gut health, ByeBark helps interrupt barking, CalmiCollar supports calmer behavior, PawPoint covers ear hygiene, and The Leash Walk Formula is the broadest step-by-step system for households that want training support built into the routine.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi FAQ",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item", "settings": { "question": "Why does the homepage lead with only two product cards if there are five products?", "answer": "<p>The homepage is designed to keep the first shopping decision calm and guided. Two featured cards make the entry point clearer, while the full five-product lineup still appears below in the category and system sections so you can see how everything fits together.</p>" } },
        { "type": "faq_item", "settings": { "question": "Can I use more than one product in the routine?", "answer": "<p>Yes, many households will shop across more than one care lane. Because the lineup covers different needs, it is reasonable to pair essentials when your pet needs support in more than one area. If your pet is already under veterinary care or taking medications, check with your veterinarian first.</p>" } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
