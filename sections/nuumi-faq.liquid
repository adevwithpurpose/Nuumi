{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-faq section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-faq__header center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-faq__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="nuumi-faq__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-faq__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-faq__list">
      {%- for block in section.blocks -%}
        <details class="nuumi-faq__item" {% if forloop.first %}open{% endif %} {{ block.shopify_attributes }}>
          <summary class="nuumi-faq__question">
            <span>{{ block.settings.question | escape }}</span>
            <span class="nuumi-faq__toggle" aria-hidden="true"></span>
          </summary>
          <div class="nuumi-faq__answer rte">
            {{ block.settings.answer }}
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi FAQ",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Frequently asked"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions pet parents ask before they buy"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Keep answers short, clear, and confidence-building. This section should reduce friction right before the footer and final conversion prompts.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How quickly should customers expect to see results?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Set expectations clearly and conservatively. Explain that routines work best when used consistently and paired with the pet's everyday needs.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi FAQ",
      "blocks": [
        { "type": "faq_item" },
        { "type": "faq_item", "settings": { "question": "Can merchants update this copy without code?", "answer": "<p>Yes. Every question and answer is block-based, so the Theme Editor controls the entire FAQ list.</p>" } },
        { "type": "faq_item", "settings": { "question": "How should trust claims be handled?", "answer": "<p>Keep them specific, evidence-backed, and tied to ingredient, manufacturing, or guarantee language already visible on the page.</p>" } }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
