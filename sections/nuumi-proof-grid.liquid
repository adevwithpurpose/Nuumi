{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-proof-grid section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-proof-grid__header center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-proof-grid__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="nuumi-proof-grid__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-proof-grid__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-proof-grid__container">
      {%- for block in section.blocks -%}
        <div class="nuumi-proof-grid__item" {{ block.shopify_attributes }}>
          <div class="nuumi-proof-grid__card">
            {%- if block.settings.icon != 'none' -%}
              <div class="nuumi-proof-grid__icon-wrapper">
                {% render 'nuumi-icons', icon: block.settings.icon, class: 'nuumi-proof-grid__icon' %}
              </div>
            {%- endif -%}
            
            <div class="nuumi-proof-grid__content">
              {%- if block.settings.title != blank -%}
                <h3 class="nuumi-proof-grid__item-title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
              
              {%- if block.settings.description != blank -%}
                <p class="nuumi-proof-grid__item-description">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Proof Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Trust that carries through"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why Choose Nuumi?"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>These proof points set up the promise behind every Nuumi formula: credible ingredients, dependable manufacturing, and reassurance close to the buying journey.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "proof_item",
      "name": "Proof Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "paw", "label": "Paw" },
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "check_mark", "label": "Check Mark" },
            { "value": "star", "label": "Star" },
            { "value": "truck", "label": "Truck" },
            { "value": "return", "label": "Return" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "check_mark"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Vet Formulated"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Developed with top veterinarians to ensure the highest standards of pet wellness."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Proof Grid",
      "blocks": [
        {
          "type": "proof_item",
          "settings": {
            "icon": "science",
            "title": "VET FORMULATED",
            "description": "Expertly crafted for optimal pet health and longevity."
          }
        },
        {
          "type": "proof_item",
          "settings": {
            "icon": "shield",
            "title": "MADE IN THE USA",
            "description": "Manufactured in FDA-registered facilities with premium ingredients."
          }
        },
        {
          "type": "proof_item",
          "settings": {
            "icon": "return",
            "title": "30-DAY GUARANTEE",
            "description": "Love it or your money back. No questions asked."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
