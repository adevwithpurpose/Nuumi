{{ 'nuumi-home.css' | asset_url | stylesheet_tag }}

<section class="nuumi-proof-grid section-{{ section.id }}-padding">
  <div class="page-width">
    <div class="nuumi-proof-grid__header center">
      {%- if section.settings.eyebrow != blank -%}
        <p class="nuumi-proof-grid__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2 class="nuumi-proof-grid__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <div class="nuumi-proof-grid__description rte">{{ section.settings.description }}</div>
      {%- endif -%}
    </div>

    <div class="nuumi-proof-grid__container">
      {%- for block in section.blocks -%}
        <div class="nuumi-proof-grid__item" {{ block.shopify_attributes }}>
          <div class="nuumi-proof-grid__card">
            <div class="nuumi-proof-grid__icon-wrapper">
              {% render 'nuumi-icon-media', icon_source: block.settings.icon_source, icon: block.settings.icon, custom_svg: block.settings.custom_svg, image: block.settings.custom_image, wrapper_class: 'nuumi-proof-grid__icon', icon_class: 'nuumi-proof-grid__icon', image_width: 96, image_sizes: '48px', image_widths: '48, 72, 96', alt: block.settings.title %}
            </div>
            
            <div class="nuumi-proof-grid__content">
              {%- if block.settings.title != blank -%}
                <h3 class="nuumi-proof-grid__item-title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
              
              {%- if block.settings.description != blank -%}
                <p class="nuumi-proof-grid__item-description">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumi Proof Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "The Nuumipet standard"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why the homepage is built to feel calmer and easier to trust"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Nuumipet is a focused set of formulas and tools built for the issues pet parents are already trying to solve at home, with a simpler path from problem to product.</p>"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "proof_item",
      "name": "Proof Item",
      "settings": [
        {
          "type": "select",
          "id": "icon_source",
          "label": "Icon Source",
          "options": [
            { "value": "icon", "label": "Theme Icon" },
            { "value": "svg", "label": "Custom SVG" },
            { "value": "image", "label": "Image" }
          ],
          "default": "icon"
        },
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "paw", "label": "Paw" },
            { "value": "science", "label": "Science" },
            { "value": "shield", "label": "Shield" },
            { "value": "check_mark", "label": "Check Mark" },
            { "value": "star", "label": "Star" },
            { "value": "truck", "label": "Truck" },
            { "value": "return", "label": "Return" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "check_mark"
        },
        {
          "type": "textarea",
          "id": "custom_svg",
          "label": "Custom SVG Markup"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Targeted support"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Each product is built around a clear job, whether that is gut support, bark interruption, calming support, or ear hygiene."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumi Proof Grid",
      "blocks": [
        {
          "type": "proof_item",
          "settings": {
            "icon": "science",
            "title": "START WITH THE PROBLEM",
            "description": "The lineup is organized around the issues pet parents tend to notice first, so it is easier to choose a starting point without guessing."
          }
        },
        {
          "type": "proof_item",
          "settings": {
            "icon": "shield",
            "title": "LEANER CATALOG",
            "description": "Instead of padding the store with lookalike products, Nuumipet keeps the range small enough that each essential can hold a clear job."
          }
        },
        {
          "type": "proof_item",
          "settings": {
            "icon": "return",
            "title": "SHOP WITH MORE CLARITY",
            "description": "The goal is not to overwhelm you with claims. It is to make the daily routine easier to understand, easier to shop, and easier to stick with."
          }
        }
      ]
    }
  ]
}
{% endschema %}

<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>
