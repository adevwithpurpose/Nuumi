{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="nuumi-section nuumi-proof-grid section-{{ section.id }}-padding">
  <div class="page-width nuumi-home-reveal">
    <div class="nuumi-section-header nuumi-proof-grid__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="nuumi-kicker">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        <h2 class="nuumi-section-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.intro != blank -%}
          <div class="nuumi-proof-grid__intro rte">{{ section.settings.intro }}</div>
        {%- endif -%}
      </div>
    </div>

    <div class="nuumi-proof-grid__cards">
      {%- for block in section.blocks -%}
        <article class="nuumi-proof-card" {{ block.shopify_attributes }}>
          <span class="nuumi-proof-card__icon">{% render 'nuumi-icons', icon: block.settings.icon %}</span>
          <span class="nuumi-proof-card__eyebrow">{{ block.settings.eyebrow }}</span>
          <h3 class="nuumi-proof-card__title">{{ block.settings.title }}</h3>
          <div class="nuumi-proof-card__text rte">{{ block.settings.text }}</div>
          {%- if block.settings.image != blank -%}
            <div class="nuumi-proof-card__image">
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag:
                  widths: '320, 533, 800',
                  loading: 'lazy',
                  sizes: '(min-width: 990px) 30vw, 90vw'
              }}
            </div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Nuumipet Proof Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Proof that feels concrete"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Support the promise with quality signals, proof points, and merchant-ready trust blocks"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Mix testimonials, guarantees, certifications, or operational proof here so the homepage earns confidence before the customer reaches the PDP.</p>"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "proof_card",
      "name": "Proof card",
      "limit": 6,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "science", "label": "Science" },
            { "value": "shipping", "label": "Shipping" },
            { "value": "heart", "label": "Heart" },
            { "value": "check", "label": "Check" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow",
          "default": "Trust signal"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Clarity shoppers can feel"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Summarize the proof point in plain language, keeping the tone reassuring and specific.</p>"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Optional image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Nuumipet Proof Grid",
      "blocks": [
        { "type": "proof_card" },
        { "type": "proof_card" },
        { "type": "proof_card" }
      ]
    }
  ]
}
{% endschema %}
